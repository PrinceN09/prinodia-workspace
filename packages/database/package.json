{
  "name": "@prinodia/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, migrations, and database client for Prinodia Workspace",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:migrate:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "db:seed": "dotenv -e ../../.env -- ts-node --transpile-only prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -- ts-node --transpile-only prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.17.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^2.4.3",
    "dotenv-cli": "^7.4.4",
    "prisma": "^5.17.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
