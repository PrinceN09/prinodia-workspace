  USER_SUSPENDED
  USER_REACTIVATED
  USER_UNLOCKED
  ACCOUNT_LOCKED
  // Roles & Permissions
  ROLE_ASSIGNED
  ROLE_REMOVED
  PERMISSION_CHANGED
  // Sessions
  SESSION_CREATED
  SESSION_REVOKED
  // Content (legacy compat)
  FILE_UPLOADED
  FILE_DOWNLOADED
  FILE_DELETED
  MESSAGE_SENT
