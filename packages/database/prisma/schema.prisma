// =============================================================================
// GOVERNMENT STRUCTURE
// =============================================================================

model Ministry {
  id                     String                    @id @default(cuid())
  name                   String                    @db.VarChar(255)
  nameTranslations       Json                      @default("{}")
  code                   String                    @unique @db.VarChar(50)
  description            String?                   @db.Text
  logoUrl                String?                   @db.VarChar(500)
  isActive               Boolean                   @default(true)
  organizationId         String?
  organization           Organization?             @relation("OrganizationMinistries", fields: [organizationId], references: [id])
  departments            Department[]
  positions              Position[]
  offices                Office[]
  users                  User[]
  channels               Channel[]
  userRoles              UserRoleAssignment[]
  documents              Document[]
  documentShares         DocumentShare[]
  documentTemplates      DocumentTemplate[]
  workflowTemplates      WorkflowTemplate[]
  workflowDefinitions    WorkflowDefinition[]
  calendarEvents         CalendarEvent[]
  rooms                  Room[]
  executiveOffices       ExecutiveOffice[]
  responsibleDecisions   CabinetDecision[]
  implementationMinistry DecisionImplementation[]
  correspondenceSent     ExecutiveCorrespondence[]
  targetAnnouncements    ExecutiveAnnouncement[]
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  @@index([code])
  @@map("ministries")
}

model Department {
  id               String               @id @default(cuid())
  ministryId       String
  ministry         Ministry             @relation(fields: [ministryId], references: [id])
  name             String               @db.VarChar(255)
  nameTranslations Json                 @default("{}")
  code             String               @db.VarChar(50)
  description      String?              @db.Text
  isActive         Boolean              @default(true)
  organizationId   String?
  organization     Organization?        @relation("OrganizationDepartments", fields: [organizationId], references: [id])
  divisions        Division[]
  positions        Position[]
  users            User[]
  channels         Channel[]
  userRoles        UserRoleAssignment[]
  documents        Document[]
  documentShares   DocumentShare[]
  calendarEvents   CalendarEvent[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([ministryId, code])
  @@index([ministryId])
  @@map("departments")
}

model Division {
  id               String               @id @default(cuid())
  departmentId     String
  department       Department           @relation(fields: [departmentId], references: [id])
  name             String               @db.VarChar(255)
  nameTranslations Json                 @default("{}")
  code             String               @db.VarChar(50)
  description      String?              @db.Text
  isActive         Boolean              @default(true)
  users            User[]
  userRoles        UserRoleAssignment[]
  positions        Position[]
  channels         Channel[]
  documents        Document[]
  documentShares   DocumentShare[]
  calendarEvents   CalendarEvent[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@unique([departmentId, code])
  @@index([departmentId])
  @@map("divisions")
}

model Province {
  id               String          @id @default(cuid())
  name             String          @db.VarChar(255)
  nameTranslations Json            @default("{}")
  code             String          @unique @db.VarChar(10)
  capital          String?         @db.VarChar(255)
  isActive         Boolean         @default(true)
  offices          Office[]
  channels         Channel[]
  calendarEvents   CalendarEvent[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([code])
  @@map("provinces")
}

model Office {
  id         String     @id @default(cuid())
  provinceId String
  province   Province   @relation(fields: [provinceId], references: [id])
  ministryId String?
  ministry   Ministry?  @relation(fields: [ministryId], references: [id])
  name       String     @db.VarChar(255)
  code       String     @db.VarChar(50)
  address    String?    @db.Text
  isActive   Boolean    @default(true)
  positions  Position[]
  users      User[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([provinceId, code])
  @@index([provinceId])
  @@index([ministryId])
  @@map("offices")
}

enum PositionLevel {
  EXECUTIVE // Minister, Secretary-General
  DIRECTOR // Director-General, Director
  MANAGER // Division Chief, Section Chief
  SPECIALIST // Senior officer, Specialist
  OFFICER // Standard civil servant
  SUPPORT // Administrative support
}

model Position {
  id                String               @id @default(cuid())
  title             String               @db.VarChar(255)
  titleTranslations Json                 @default("{}")
  code              String               @db.VarChar(50)
  level             PositionLevel        @default(OFFICER)
  headcount         Int                  @default(1)
  ministryId        String?
  ministry          Ministry?            @relation(fields: [ministryId], references: [id])
  departmentId      String?
  department        Department?          @relation(fields: [departmentId], references: [id])
  divisionId        String?
  division          Division?            @relation(fields: [divisionId], references: [id])
  officeId          String?
  office            Office?              @relation(fields: [officeId], references: [id])
  isActive          Boolean              @default(true)
  assignments       EmployeeAssignment[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([ministryId, code])
  @@index([ministryId])
  @@index([departmentId])
  @@index([divisionId])
  @@index([level])
  @@map("positions")
}

model EmployeeAssignment {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  positionId   String
  position     Position  @relation(fields: [positionId], references: [id])
  startDate    DateTime
  endDate      DateTime?
  isPrimary    Boolean   @default(true)
  isActive     Boolean   @default(true)
  notes        String?   @db.Text
  assignedById String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([positionId])
  @@index([isActive])
  @@map("employee_assignments")
}

// =============================================================================
// USERS & IDENTITY
// =============================================================================

model User {
  id                         String                    @id @default(cuid())
  // Matricule — government-issued ID (e.g. "1.641.558", "478.432", "424.55")
  // MUST be stored as string: dots, varying formats, leading zeros must be preserved
  // Deprecated: use employeeNumber for new org types. Kept for backward compat.
  matriculeNumber            String?                   @unique @db.VarChar(50)
  // Universal login identifier — auto-generated as firstName.lastName if not provided.
  // Unique per platform (future: per-organization uniqueness via composite index).
  username                   String?                   @unique @db.VarChar(100)
  // Employee number — org-scoped identifier for non-government orgs (e.g. EMP-00125).
  // Nullable and NOT globally unique: uniqueness is enforced per-org via @@index.
  employeeNumber             String?                   @db.VarChar(100)
  email                      String                    @unique @db.VarChar(255)
  passwordHash               String                    @db.VarChar(255)
  firstName                  String                    @db.VarChar(100)
  lastName                   String                    @db.VarChar(100)
  displayName                String                    @db.VarChar(200)
  avatarUrl                  String?                   @db.VarChar(500)
  userType                   UserType                  @default(GOVERNMENT_EMPLOYEE)
  // Legacy single-role field — kept for quick permission checks.
  // Source of truth is UserRoleAssignment join table.
  role                       UserRole                  @default(EMPLOYEE)
  status                     UserStatus                @default(PENDING)
  preferredLanguage          SupportedLanguage         @default(fr)
  // MFA
  mfaEnabled                 Boolean                   @default(false)
  mfaSecret                  String?                   @db.VarChar(512) // AES-256-GCM encrypted
  // Security tracking
  failedLoginCount           Int                       @default(0)
  lockedUntil                DateTime?
  passwordChangedAt          DateTime?
  lastLoginAt                DateTime?
  lastLoginIp                String?                   @db.VarChar(50)
  // Contact
  phone                      String?                   @db.VarChar(50)
  // Government structure
  ministryId                 String?
  ministry                   Ministry?                 @relation(fields: [ministryId], references: [id])
  departmentId               String?
  department                 Department?               @relation(fields: [departmentId], references: [id])
  divisionId                 String?
  division                   Division?                 @relation(fields: [divisionId], references: [id])
  officeId                   String?
  office                     Office?                   @relation(fields: [officeId], references: [id])
  // Organization (v1.0.2 — neutral parent model)
  organizationId             String?
  organization               Organization?             @relation("OrganizationUsers", fields: [organizationId], references: [id])
  // Manager (self-relation)
  managerId                  String?
  manager                    User?                     @relation("Subordinates", fields: [managerId], references: [id])
  subordinates               User[]                    @relation("Subordinates")
  // Identity relations
  roleAssignments            UserRoleAssignment[]
  sessions                   UserSession[]
  devices                    UserDevice[]
  loginHistory               LoginHistory[]
  passwordResetTokens        PasswordResetToken[]
  passwordHistory            PasswordHistory[]
  mfaDevices                 MfaDevice[]
  mfaBackupCodes             MfaBackupCode[]
  invitations                EmployeeInvitation[]
  // Government structure
  employeeAssignments        EmployeeAssignment[]
  workforceTransfers         WorkforceTransfer[]
  // Collaboration relations (v0.7.0)
  sentMessages               Message[]                 @relation("SentMessages")
  channelMemberships         ChannelMember[]
  receivedMentions           Mention[]                 @relation("ReceivedMentions")
  readReceipts               ReadReceipt[]             @relation("ReadReceipts")
  conversationMemberships    ConversationMember[]      @relation("ConversationMemberships")
  sentDirectMessages         DirectMessage[]           @relation("SentDirectMessages")
  dmReactions                DMReaction[]              @relation("DMReactions")
  conversationSettings       ConversationSettings[]    @relation("ConversationSettings")
  notifications              Notification[]
  auditLogs                  AuditLog[]
  uploadedFiles              File[]
  // Document relations (v0.8.0)
  authoredDocuments          Document[]                @relation("AuthoredDocuments")
  savedVersions              DocumentVersion[]         @relation("SavedVersions")
  documentShares             DocumentShare[]           @relation("SharingUser")
  receivedShares             DocumentShare[]           @relation("SharedWithUser")
  documentComments           DocumentComment[]         @relation("DocumentComments")
  createdTemplates           DocumentTemplate[]        @relation("CreatedTemplates")
  documentExports            DocumentExport[]          @relation("DocumentExports")
  approvalRequests           DocumentApproval[]        @relation("ApprovalRequests")
  approvalReviews            DocumentApproval[]        @relation("DocumentApprovals")
  // Workflow relations (v0.8.1)
  createdWorkflowTemplates   WorkflowTemplate[]        @relation("CreatedWorkflowTemplates")
  createdWorkflowDefinitions WorkflowDefinition[]      @relation("CreatedWorkflowDefinitions")
  assignedWorkflowSteps      WorkflowStep[]            @relation("WorkflowStepAssignees")
  initiatedWorkflows         WorkflowInstance[]        @relation("InitiatedWorkflows")
  cancelledWorkflows         WorkflowInstance[]        @relation("CancelledWorkflows")
  workflowAssignments        WorkflowAssignment[]      @relation("WorkflowAssignments")
  workflowApprovals          WorkflowApproval[]        @relation("WorkflowApprovals")
  delegatedApprovals         WorkflowApproval[]        @relation("DelegatedApprovals")
  workflowComments           WorkflowComment[]         @relation("WorkflowComments")
  workflowHistory            WorkflowHistory[]         @relation("WorkflowHistory")
  digitalSignatures          DigitalSignature[]        @relation("DigitalSignatures")
  revokedSignatures          DigitalSignature[]        @relation("RevokedSignatures")
  assignedTasks              Task[]                    @relation("AssignedTasks")
  createdTasks               Task[]                    @relation("CreatedTasks")
  taskComments               TaskComment[]             @relation("TaskComments")
  taskAttachments            TaskAttachment[]          @relation("TaskAttachments")
  // Executive Office (v1.0.0)
  headedOffices              ExecutiveOffice[]         @relation("ExecutiveOfficeHead")
  executiveOfficeStaff       ExecutiveOfficeStaff[]    @relation("ExecutiveOfficeStaff")
  chairedSessions            CabinetSession[]          @relation("CabinetChair")
  secretariatSessions        CabinetSession[]          @relation("CabinetSecretary")
  createdCabinetSessions     CabinetSession[]          @relation("CabinetSessionCreator")
  cabinetAgendaPresentations CabinetAgendaItem[]       @relation("CabinetAgendaPresenters")
  ownedDecisions             CabinetDecision[]         @relation("DecisionOwners")
  adoptedDecisions           CabinetDecision[]         @relation("DecisionAdoptedBy")
  createdDecisions           CabinetDecision[]         @relation("DecisionCreators")
  implementationAssignments  DecisionImplementation[]  @relation("ImplementationAssignees")
  createdImplementations     DecisionImplementation[]  @relation("ImplementationCreators")
  authoredBriefings          ExecutiveBriefing[]       @relation("BriefingAuthors")
  approvedBriefings          ExecutiveBriefing[]       @relation("BriefingApprovers")
  sentCorrespondence         ExecutiveCorrespondence[] @relation("CorrespondenceSenders")
  receivedCorrespondence     ExecutiveCorrespondence[] @relation("CorrespondenceRecipients")
  authoredAnnouncements      ExecutiveAnnouncement[]   @relation("AnnouncementAuthors")
  // Calendar & Meetings (v0.9.0)
  createdEvents              CalendarEvent[]           @relation("CreatedEvents")
  eventReminders             EventReminder[]           @relation("EventReminders")
  organizedMeetings          Meeting[]                 @relation("OrganizedMeetings")
  meetingParticipations      MeetingParticipant[]      @relation("MeetingParticipations")
  delegatedParticipations    MeetingParticipant[]      @relation("DelegatedParticipations")
  agendaPresentations        MeetingAgendaItem[]       @relation("AgendaPresenters")
  meetingMinutesAuthored     MeetingMinutes[]          @relation("MeetingMinutesAuthor")
  meetingMinutesPublished    MeetingMinutes[]          @relation("MeetingMinutesPublisher")
  meetingAttachments         MeetingAttachment[]       @relation("MeetingAttachments")
  roomBookings               RoomBooking[]             @relation("RoomBookings")
  // Realtime (v1.2.0)
  connections                UserConnection[]          @relation("UserConnections")
  activityEvents             ActivityEvent[]           @relation("UserActivityEvents")
  // Chat v1.4.0
  drafts                     Draft[]                   @relation("UserDrafts")
  bookmarks                  Bookmark[]                @relation("UserBookmarks")
  // Meet v1.5.0
  meetSessionsHosted         MeetingSession[]          @relation("MeetSessionHost")
  meetRecordingsStarted      MeetingRecording[]        @relation("MeetRecordingStarter")
  meetReactions              MeetingReaction[]         @relation("MeetReactions")
  meetPollVotes              MeetingPollVote[]         @relation("MeetPollVotes")
  meetPollsCreated           MeetingPoll[]             @relation("MeetPollCreator")
  meetInvitesCreated         MeetingInvite[]           @relation("MeetInvites")
  meetBreakoutParticipations MeetingBreakoutRoomParticipant[] @relation("BreakoutParticipant")
  meetSummariesAuthored      MeetingSummary[]          @relation("MeetSummaryAuthor")
  // Canvas v1.6.0
  canvasBoardsOwned          CanvasBoard[]             @relation("CanvasBoardOwner")
  canvasParticipations       CanvasParticipant[]       @relation("CanvasParticipations")
  canvasElementsCreated      CanvasElement[]           @relation("CanvasElementCreator")
  canvasVersionsEdited       CanvasElementVersion[]    @relation("CanvasVersionEditor")
  canvasSessionsStarted      CanvasSession[]           @relation("CanvasSessionStarter")
  canvasCommentsAuthored     CanvasComment[]           @relation("CanvasCommentAuthor")
  canvasTemplatesCreated     CanvasTemplate[]          @relation("CanvasTemplateCreator")
  canvasExportsRequested     CanvasExport[]            @relation("CanvasExportRequester")
  canvasSharesCreated        CanvasShare[]             @relation("CanvasShareCreator")
  canvasPresences            CanvasPresence[]          @relation("CanvasPresences")
  canvasActivities           CanvasActivity[]          @relation("CanvasActivities")
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  deletedAt                  DateTime?

  @@index([email])
  @@index([matriculeNumber])
  @@index([ministryId])
  @@index([departmentId])
  @@index([officeId])
  @@index([managerId])
  @@index([role])
  @@index([status])
  @@index([employeeNumber])
  @@index([organizationId, employeeNumber])
  @@map("users")
}

// =============================================================================
// EMPLOYEE INVITATIONS (v0.6.0)
// =============================================================================

model EmployeeInvitation {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SHA-256 hash of the raw invitation token (raw token is in the email only)
  tokenHash   String    @unique @db.VarChar(255)
  expiresAt   DateTime
  used        Boolean   @default(false)
  usedAt      DateTime?
  invitedById String
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@map("employee_invitations")
}

// =============================================================================
// WORKFORCE TRANSFERS (v0.6.1)
// =============================================================================

model WorkforceTransfer {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transferredById  String
  // Organizational "from" snapshot (null = unchanged / no prior value)
  fromMinistryId   String?
  fromDepartmentId String?
  fromDivisionId   String?
  fromOfficeId     String?
  fromManagerId    String?
  fromPositionId   String?
  // Organizational "to" values
  toMinistryId     String?
  toDepartmentId   String?
  toDivisionId     String?
  toOfficeId       String?
  toManagerId      String?
  toPositionId     String?
  reason           String?  @db.Text
  effectiveDate    DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("workforce_transfers")
}

// =============================================================================
// RBAC — ROLES & PERMISSIONS
// =============================================================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  displayName String   @db.VarChar(255)
  weight      Int
  isSystem    Boolean  @default(false)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  assignments UserRoleAssignment[]

  @@index([weight])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(100)
  displayName String   @db.VarChar(255)
  description String?  @db.Text
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// Scoped role assignment: a user may hold different roles in different orgs
model UserRoleAssignment {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId       String
  role         Role        @relation(fields: [roleId], references: [id])
  // Organizational scope (null = system-wide)
  ministryId   String?
  ministry     Ministry?   @relation(fields: [ministryId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  divisionId   String?
  division     Division?   @relation(fields: [divisionId], references: [id])
  grantedById  String
  grantedAt    DateTime    @default(now())
  expiresAt    DateTime?
  isActive     Boolean     @default(true)

  @@unique([userId, roleId, ministryId, departmentId, divisionId])
  @@index([userId])
  @@index([roleId])
  @@index([ministryId])
  @@map("user_role_assignments")
}

// =============================================================================
// SESSIONS & DEVICES
// =============================================================================

model UserSession {
  id              String      @id @default(cuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId        String?
  device          UserDevice? @relation(fields: [deviceId], references: [id])
  // Hashed JTI of the active refresh token (for rotation validation)
  refreshTokenJti String?     @db.VarChar(255)
  // Token family for reuse detection
  tokenFamily     String      @db.VarChar(100)
  ipAddress       String      @db.VarChar(50)
  userAgent       String      @db.Text
  platform        String      @db.VarChar(50) // "web" | "desktop" | "mobile"
  isActive        Boolean     @default(true)
  lastUsedAt      DateTime    @default(now())
  revokedAt       DateTime?
  expiresAt       DateTime
  createdAt       DateTime    @default(now())

  @@index([userId])
  @@index([refreshTokenJti])
  @@index([tokenFamily])
  @@index([isActive])
  @@index([userId, isActive]) // compound: active sessions per user (v0.6.3)
  @@map("user_sessions")
}

model UserDevice {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(255)
  platform    String   @db.VarChar(50)
  fingerprint String   @db.VarChar(255)
  trusted     Boolean  @default(false)
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  sessions UserSession[]

  @@unique([userId, fingerprint])
  @@index([userId])
  @@map("user_devices")
}

// =============================================================================
// LOGIN HISTORY
// =============================================================================

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  credential String   @db.VarChar(255) // matricule or email used (for auditing)
  success    Boolean
  failReason String?  @db.VarChar(100)
  ipAddress  String   @db.VarChar(50)
  userAgent  String   @db.Text
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([ipAddress])
  @@index([createdAt])
  @@map("login_history")
}

// =============================================================================
// PASSWORD MANAGEMENT
// =============================================================================

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SHA-256 hash of the raw token (raw token is in the email link only)
  tokenHash String    @unique @db.VarChar(255)
  used      Boolean   @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("password_history")
}

// =============================================================================
// MFA
// =============================================================================

model MfaDevice {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String    @db.VarChar(255)
  method       MfaMethod @default(TOTP)
  // FIDO2 / WebAuthn fields (future)
  credentialId String?   @db.VarChar(512)
  publicKey    String?   @db.Text
  counter      Int?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
  @@map("mfa_devices")
}

model MfaBackupCode {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String    @db.VarChar(255) // bcrypt hash
  isUsed    Boolean   @default(false)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("mfa_backup_codes")
}

// =============================================================================
// CHANNELS & MESSAGING
// =============================================================================

model Channel {
  id             String          @id @default(cuid())
  name           String          @db.VarChar(100)
  slug           String?         @db.VarChar(120) // URL-safe name
  description    String?         @db.Text
  type           ChannelType     @default(PUBLIC)
  // Organizational scope — a channel belongs to exactly one org unit
  ministryId     String?
  ministry       Ministry?       @relation(fields: [ministryId], references: [id])
  departmentId   String?
  department     Department?     @relation(fields: [departmentId], references: [id])
  divisionId     String?
  division       Division?       @relation(fields: [divisionId], references: [id])
  provinceId     String?
  province       Province?       @relation(fields: [provinceId], references: [id])
  organizationId String?         // v1.4.0 — org-wide channels
  organization   Organization?   @relation("ChannelOrganization", fields: [organizationId], references: [id])
  isArchived     Boolean         @default(false)
  archivedAt     DateTime?
  archivedById   String?
  createdById    String
  memberCount    Int             @default(0) // denormalised for perf
  lastMessageAt  DateTime?
  members        ChannelMember[]
  messages       Message[]
  pinnedMessages PinnedMessage[]
  mentions       Mention[]
  files          File[]
  drafts         Draft[]         // v1.4.0
  meetingLinked  Meeting?        @relation("MeetingChannel") // v1.5.0
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([ministryId])
  @@index([departmentId])
  @@index([divisionId])
  @@index([provinceId])
  @@index([organizationId])
  @@index([type])
  @@index([isArchived])
  @@map("channels")
}

model ChannelMember {
  id                String    @id @default(cuid())
  channelId         String
  channel           Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isAdmin           Boolean   @default(false)
  muteNotifications Boolean   @default(false)
  joinedAt          DateTime  @default(now())
  lastReadAt        DateTime  @default(now())
  leftAt            DateTime?

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
  @@index([channelId, lastReadAt])
  @@map("channel_members")
}

model Message {
  id            String         @id @default(cuid())
  channelId     String
  channel       Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId      String
  sender        User           @relation("SentMessages", fields: [senderId], references: [id])
  type          MessageType    @default(TEXT)
  content       String         @db.Text
  replyToId     String?
  replyTo       Message?       @relation("Replies", fields: [replyToId], references: [id])
  replies       Message[]      @relation("Replies")
  isPinned      Boolean        @default(false)
  pinnedMessage PinnedMessage?
  reactions     Reaction[]
  mentions      Mention[]
  readReceipts  ReadReceipt[]
  attachments   File[]         @relation("MessageFiles")
  bookmarks     Bookmark[]     // v1.4.0
  history       MessageHistory[] // v1.4.0
  editedAt      DateTime?
  deletedAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([channelId])
  @@index([senderId])
  @@index([createdAt])
  @@index([channelId, createdAt]) // cursor pagination
  @@map("messages")
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String   @db.VarChar(20)
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("reactions")
}

model PinnedMessage {
  id         String   @id @default(cuid())
  messageId  String   @unique
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  channelId  String
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  pinnedById String
  pinnedAt   DateTime @default(now())

  @@index([channelId])
  @@map("pinned_messages")
}

model Mention {
  id            String    @id @default(cuid())
  messageId     String
  message       Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  channelId     String
  channel       Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  // Who was mentioned
  userId        String
  user          User      @relation("ReceivedMentions", fields: [userId], references: [id], onDelete: Cascade)
  mentionedById String
  isRead        Boolean   @default(false)
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  @@index([userId, isRead])
  @@index([messageId])
  @@index([channelId])
  @@map("mentions")
}

model ReadReceipt {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("ReadReceipts", fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@map("read_receipts")
}

// =============================================================================
// DIRECT MESSAGES & CONVERSATIONS (v0.7.0)
// Separate from org Channels — these are personal DMs and group chats.
// =============================================================================

model Conversation {
  id            String                 @id @default(cuid())
  type          ConversationType       @default(DIRECT)
  name          String?                @db.VarChar(255) // null for 1:1 DMs
  avatarUrl     String?                @db.VarChar(500)
  createdById   String
  isArchived    Boolean                @default(false)
  lastMessageAt DateTime?
  members       ConversationMember[]
  messages      DirectMessage[]
  settings      ConversationSettings[]
  drafts        Draft[]                // v1.4.0
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([createdById])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("ConversationMemberships", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime     @default(now())
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_members")
}

model DirectMessage {
  id             String          @id @default(cuid())
  conversationId String
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User            @relation("SentDirectMessages", fields: [senderId], references: [id])
  type           MessageType     @default(TEXT)
  content        String          @db.Text
  replyToId      String?
  replyTo        DirectMessage?  @relation("DMReplies", fields: [replyToId], references: [id])
  replies        DirectMessage[] @relation("DMReplies")
  reactions      DMReaction[]
  bookmarks      Bookmark[]     // v1.4.0
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([conversationId, createdAt]) // cursor pagination
  @@index([senderId])
  @@map("direct_messages")
}

model DMReaction {
  id        String        @id @default(cuid())
  messageId String
  message   DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation("DMReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String        @db.VarChar(20)
  createdAt DateTime      @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("dm_reactions")
}

model ConversationSettings {
  id                String       @id @default(cuid())
  conversationId    String
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId            String
  user              User         @relation("ConversationSettings", fields: [userId], references: [id], onDelete: Cascade)
  muteNotifications Boolean      @default(false)
  mutedUntil        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@map("conversation_settings")
}

// =============================================================================
// CHAT v1.4.0 — Drafts, Bookmarks, Message History
// =============================================================================

// Draft — unsent message content, persisted per user × channel/conversation.
// One draft per (user, channel) and one per (user, conversation).
model Draft {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation("UserDrafts", fields: [userId], references: [id], onDelete: Cascade)
  channelId      String?
  channel        Channel?      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  content        String        @db.Text
  replyToId      String?       // Optional: drafting a reply to this message ID
  updatedAt      DateTime      @updatedAt
  createdAt      DateTime      @default(now())

  @@unique([userId, channelId])
  @@unique([userId, conversationId])
  @@index([userId])
  @@map("drafts")
}

// Bookmark — save any channel message or DM for later reference.
model Bookmark {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation("UserBookmarks", fields: [userId], references: [id], onDelete: Cascade)
  messageId String?
  message   Message?       @relation(fields: [messageId], references: [id], onDelete: Cascade)
  dmId      String?
  dm        DirectMessage? @relation(fields: [dmId], references: [id], onDelete: Cascade)
  note      String?        @db.VarChar(500)
  createdAt DateTime       @default(now())

  @@unique([userId, messageId])
  @@unique([userId, dmId])
  @@index([userId])
  @@map("bookmarks")
}

// MessageHistory — stores each prior version of a message's content when edited.
model MessageHistory {
  id         String   @id @default(cuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  content    String   @db.Text
  editedById String
  editedAt   DateTime @default(now())

  @@index([messageId])
  @@map("message_history")
}

// =============================================================================
// FILE STORAGE
// NOTE: Actual files are stored in MinIO/S3. Only metadata lives here.
// =============================================================================

model File {
  id           String       @id @default(cuid())
  name         String       @db.VarChar(255)
  originalName String       @db.VarChar(255)
  mimeType     String       @db.VarChar(127)
  size         BigInt
  category     FileCategory @default(OTHER)
  status       FileStatus   @default(PENDING)
  storageKey   String       @db.VarChar(500)
  bucketName   String       @db.VarChar(100)
  checksum     String?      @db.VarChar(64)
  uploadedById String
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  channelId    String?
  channel      Channel?     @relation(fields: [channelId], references: [id])
  messageId    String?
  message      Message?     @relation("MessageFiles", fields: [messageId], references: [id])
  isPublic     Boolean      @default(false)
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([uploadedById])
  @@index([channelId])
  @@index([messageId])
  @@index([storageKey])
  @@map("files")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String           @db.VarChar(255)
  body      String           @db.Text
  data      Json             @default("{}")
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================================
// AUDIT LOGS — IMMUTABLE (app user has INSERT + SELECT only, never UPDATE/DELETE)
// =============================================================================

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  entityType String?     @db.VarChar(100)
  entityId   String?     @db.VarChar(100)
  metadata   Json        @default("{}")
  ipAddress  String?     @db.VarChar(50)
  userAgent  String?     @db.Text
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  // Compound indexes for common dashboard/filter query patterns (v0.6.3 performance)
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// =============================================================================
// DOCUMENTS & WRITER PLATFORM (v0.8.0)
// =============================================================================

model Document {
  id             String                 @id @default(cuid())
  title          String                 @db.VarChar(500)
  slug           String                 @unique @db.VarChar(500)
  type           DocumentType           @default(OTHER)
  status         DocumentStatus         @default(DRAFT)
  classification DocumentClassification @default(INTERNAL)
  // TipTap ProseMirror JSON content
  content        Json                   @default("{}")
  // Plain-text extract for search
  contentText    String?                @db.Text
  wordCount      Int                    @default(0)
  // Template reference
  templateId     String?
  template       DocumentTemplate?      @relation(fields: [templateId], references: [id])
  // Ownership
  authorId       String
  author         User                   @relation("AuthoredDocuments", fields: [authorId], references: [id])
  // Org scope (optional)
  ministryId     String?
  ministry       Ministry?              @relation(fields: [ministryId], references: [id])
  departmentId   String?
  department     Department?            @relation(fields: [departmentId], references: [id])
  divisionId     String?
  division       Division?              @relation(fields: [divisionId], references: [id])
  tags           String[]
  // Soft delete
  deletedAt      DateTime?
  deletedById    String?
  // Relations
  versions       DocumentVersion[]
  shares         DocumentShare[]
  comments       DocumentComment[]
  exports        DocumentExport[]
  approvals      DocumentApproval[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([classification])
  @@index([ministryId])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("documents")
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version     Int
  title       String   @db.VarChar(500)
  content     Json
  contentText String?  @db.Text
  wordCount   Int      @default(0)
  savedById   String
  savedBy     User     @relation("SavedVersions", fields: [savedById], references: [id])
  changeNote  String?  @db.VarChar(500)
  createdAt   DateTime @default(now())

  @@unique([documentId, version])
  @@index([documentId])
  @@index([createdAt])
  @@map("document_versions")
}

model DocumentShare {
  id                 String             @id @default(cuid())
  documentId         String
  document           Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  scope              DocumentShareScope
  // Target — exactly one set
  targetUserId       String?
  targetUser         User?              @relation("SharedWithUser", fields: [targetUserId], references: [id])
  targetMinistryId   String?
  targetMinistry     Ministry?          @relation(fields: [targetMinistryId], references: [id])
  targetDepartmentId String?
  targetDepartment   Department?        @relation(fields: [targetDepartmentId], references: [id])
  targetDivisionId   String?
  targetDivision     Division?          @relation(fields: [targetDivisionId], references: [id])
  // Permissions
  canEdit            Boolean            @default(false)
  canComment         Boolean            @default(true)
  canExport          Boolean            @default(false)
  sharedById         String
  sharedBy           User               @relation("SharingUser", fields: [sharedById], references: [id])
  expiresAt          DateTime?
  createdAt          DateTime           @default(now())

  @@index([documentId])
  @@index([targetUserId])
  @@index([targetMinistryId])
  @@index([targetDepartmentId])
  @@index([targetDivisionId])
  @@map("document_shares")
}

model DocumentComment {
  id           String            @id @default(cuid())
  documentId   String
  document     Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  authorId     String
  author       User              @relation("DocumentComments", fields: [authorId], references: [id])
  content      String            @db.Text
  replyToId    String?
  replyTo      DocumentComment?  @relation("CommentReplies", fields: [replyToId], references: [id])
  replies      DocumentComment[] @relation("CommentReplies")
  resolvedAt   DateTime?
  resolvedById String?
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([documentId])
  @@index([authorId])
  @@map("document_comments")
}

model DocumentTemplate {
  id             String                 @id @default(cuid())
  name           String                 @db.VarChar(255)
  description    String?                @db.Text
  type           DocumentType
  classification DocumentClassification @default(INTERNAL)
  content        Json                   @default("{}")
  isActive       Boolean                @default(true)
  createdById    String
  createdBy      User                   @relation("CreatedTemplates", fields: [createdById], references: [id])
  ministryId     String?
  ministry       Ministry?              @relation(fields: [ministryId], references: [id])
  documents      Document[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([type])
  @@index([ministryId])
  @@map("document_templates")
}

model DocumentExport {
  id           String               @id @default(cuid())
  documentId   String
  document     Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  format       DocumentExportFormat
  versionId    String?
  exportedById String
  exportedBy   User                 @relation("DocumentExports", fields: [exportedById], references: [id])
  fileSize     Int?
  storageKey   String?              @db.VarChar(500)
  expiresAt    DateTime?
  createdAt    DateTime             @default(now())

  @@index([documentId])
  @@index([exportedById])
  @@map("document_exports")
}

model DocumentApproval {
  id            String         @id @default(cuid())
  documentId    String
  document      Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  approverId    String
  approver      User           @relation("DocumentApprovals", fields: [approverId], references: [id])
  status        ApprovalStatus @default(PENDING)
  requestedById String
  requestedBy   User           @relation("ApprovalRequests", fields: [requestedById], references: [id])
  comment       String?        @db.Text
  reviewedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([documentId])
  @@index([approverId])
  @@index([status])
  @@map("document_approvals")
}

// =============================================================================
// WORKFLOWS & APPROVALS (v0.8.1)
// =============================================================================

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  REJECTED
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  SKIPPED
  RETURNED
  DELEGATED
}

enum ApprovalDecisionEnum {
  APPROVED
  REJECTED
  REQUEST_CHANGES
  DELEGATED
  ESCALATED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkflowTrigger {
  MANUAL
  DOCUMENT_CREATED
  DOCUMENT_PUBLISHED
  EMPLOYEE_TRANSFERRED
  BUDGET_SUBMITTED
  CONTRACT_UPLOADED
  CUSTOM
}

// ─── Workflow Templates ───────────────────────────────────────────────────────

model WorkflowTemplate {
  id              String               @id @default(cuid())
  name            String               @db.VarChar(255)
  description     String?              @db.Text
  slug            String               @unique @db.VarChar(255)
  trigger         WorkflowTrigger      @default(MANUAL)
  stepDefinitions Json                 @default("[]") // ordered array of step configs
  isSystem        Boolean              @default(false) // built-in government templates
  isActive        Boolean              @default(true)
  ministryId      String?
  ministry        Ministry?            @relation(fields: [ministryId], references: [id])
  createdById     String
  createdBy       User                 @relation("CreatedWorkflowTemplates", fields: [createdById], references: [id])
  definitions     WorkflowDefinition[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([ministryId])
  @@index([isActive])
  @@map("workflow_templates")
}

// ─── Workflow Definitions ─────────────────────────────────────────────────────

model WorkflowDefinition {
  id          String             @id @default(cuid())
  title       String             @db.VarChar(500)
  description String?            @db.Text
  templateId  String?
  template    WorkflowTemplate?  @relation(fields: [templateId], references: [id])
  trigger     WorkflowTrigger    @default(MANUAL)
  isActive    Boolean            @default(true)
  ministryId  String?
  ministry    Ministry?          @relation(fields: [ministryId], references: [id])
  createdById String
  createdBy   User               @relation("CreatedWorkflowDefinitions", fields: [createdById], references: [id])
  steps       WorkflowStep[]
  instances   WorkflowInstance[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([ministryId])
  @@index([isActive])
  @@map("workflow_definitions")
}

// ─── Workflow Steps ───────────────────────────────────────────────────────────

model WorkflowStep {
  id             String               @id @default(cuid())
  definitionId   String
  definition     WorkflowDefinition   @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  order          Int
  name           String               @db.VarChar(255)
  description    String?              @db.Text
  roleId         String? // role required to approve this step
  assigneeId     String? // specific user assigned
  assignee       User?                @relation("WorkflowStepAssignees", fields: [assigneeId], references: [id])
  durationHours  Int? // SLA
  allowDelegate  Boolean              @default(true)
  allowEscalate  Boolean              @default(true)
  requireComment Boolean              @default(false)
  requireSign    Boolean              @default(false)
  assignments    WorkflowAssignment[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([definitionId, order])
  @@index([definitionId])
  @@map("workflow_steps")
}

// ─── Workflow Instances ───────────────────────────────────────────────────────

model WorkflowInstance {
  id            String               @id @default(cuid())
  definitionId  String
  definition    WorkflowDefinition   @relation(fields: [definitionId], references: [id])
  title         String               @db.VarChar(500)
  description   String?              @db.Text
  status        WorkflowStatus       @default(DRAFT)
  currentStep   Int                  @default(0)
  totalSteps    Int                  @default(0)
  initiatorId   String
  initiator     User                 @relation("InitiatedWorkflows", fields: [initiatorId], references: [id])
  documentId    String? // optional linked document
  metadata      Json                 @default("{}")
  startedAt     DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelledById String?
  cancelledBy   User?                @relation("CancelledWorkflows", fields: [cancelledById], references: [id])
  dueAt         DateTime?
  deletedAt     DateTime?
  assignments   WorkflowAssignment[]
  approvals     WorkflowApproval[]
  comments      WorkflowComment[]
  history       WorkflowHistory[]
  tasks         Task[]
  signatures    DigitalSignature[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([status])
  @@index([initiatorId])
  @@index([definitionId])
  @@index([documentId])
  @@index([createdAt])
  @@map("workflow_instances")
}

// ─── Workflow Assignments (per-step per-instance) ─────────────────────────────

model WorkflowAssignment {
  id          String            @id @default(cuid())
  instanceId  String
  instance    WorkflowInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepId      String
  step        WorkflowStep      @relation(fields: [stepId], references: [id])
  assigneeId  String
  assignee    User              @relation("WorkflowAssignments", fields: [assigneeId], references: [id])
  stepOrder   Int
  status      StepStatus        @default(PENDING)
  dueAt       DateTime?
  notifiedAt  DateTime?
  completedAt DateTime?
  approval    WorkflowApproval?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([instanceId])
  @@index([assigneeId])
  @@index([status])
  @@map("workflow_assignments")
}

// ─── Workflow Approvals ───────────────────────────────────────────────────────

model WorkflowApproval {
  id            String               @id @default(cuid())
  instanceId    String
  instance      WorkflowInstance     @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  assignmentId  String               @unique
  assignment    WorkflowAssignment   @relation(fields: [assignmentId], references: [id])
  approverId    String
  approver      User                 @relation("WorkflowApprovals", fields: [approverId], references: [id])
  decision      ApprovalDecisionEnum
  comment       String?              @db.Text
  delegatedToId String?
  delegatedTo   User?                @relation("DelegatedApprovals", fields: [delegatedToId], references: [id])
  stepOrder     Int
  decidedAt     DateTime             @default(now())
  signature     DigitalSignature?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([instanceId])
  @@index([approverId])
  @@map("workflow_approvals")
}

// ─── Workflow Comments ────────────────────────────────────────────────────────

model WorkflowComment {
  id         String            @id @default(cuid())
  instanceId String
  instance   WorkflowInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  authorId   String
  author     User              @relation("WorkflowComments", fields: [authorId], references: [id])
  content    String            @db.Text
  replyToId  String?
  replyTo    WorkflowComment?  @relation("WorkflowReplies", fields: [replyToId], references: [id])
  replies    WorkflowComment[] @relation("WorkflowReplies")
  isInternal Boolean           @default(false)
  deletedAt  DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([instanceId])
  @@index([authorId])
  @@map("workflow_comments")
}

// ─── Workflow History ─────────────────────────────────────────────────────────

model WorkflowHistory {
  id         String           @id @default(cuid())
  instanceId String
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User             @relation("WorkflowHistory", fields: [actorId], references: [id])
  action     String           @db.VarChar(100)
  stepOrder  Int?
  detail     String?          @db.Text
  metadata   Json             @default("{}")
  createdAt  DateTime         @default(now())

  @@index([instanceId])
  @@index([createdAt])
  @@map("workflow_history")
}

// ─── Digital Signatures ───────────────────────────────────────────────────────

model DigitalSignature {
  id             String            @id @default(cuid())
  instanceId     String
  instance       WorkflowInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  approvalId     String?           @unique
  approval       WorkflowApproval? @relation(fields: [approvalId], references: [id])
  signerId       String
  signer         User              @relation("DigitalSignatures", fields: [signerId], references: [id])
  signedAt       DateTime          @default(now())
  ipAddress      String?           @db.VarChar(45)
  userAgent      String?           @db.VarChar(500)
  certificateRef String?           @db.VarChar(255) // future PKI
  qrToken        String            @unique @default(cuid()) // QR verification
  revokedAt      DateTime?
  revokedById    String?
  revokedBy      User?             @relation("RevokedSignatures", fields: [revokedById], references: [id])
  createdAt      DateTime          @default(now())

  @@index([instanceId])
  @@index([signerId])
  @@index([qrToken])
  @@map("digital_signatures")
}

// ─── Tasks ────────────────────────────────────────────────────────────────────

model Task {
  id                     String                  @id @default(cuid())
  title                  String                  @db.VarChar(500)
  description            String?                 @db.Text
  status                 TaskStatus              @default(TODO)
  priority               TaskPriority            @default(MEDIUM)
  assigneeId             String?
  assignee               User?                   @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdById            String
  createdBy              User                    @relation("CreatedTasks", fields: [createdById], references: [id])
  instanceId             String?
  instance               WorkflowInstance?       @relation(fields: [instanceId], references: [id])
  documentId             String?
  dueAt                  DateTime?
  completedAt            DateTime?
  cancelledAt            DateTime?
  deletedAt              DateTime?
  tags                   String[]                @default([])
  comments               TaskComment[]
  attachments            TaskAttachment[]
  meetingActionItem      MeetingActionItem?
  decisionImplementation DecisionImplementation?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([instanceId])
  @@index([dueAt])
  @@index([createdAt])
  @@map("tasks")
}

// ─── Task Comments ────────────────────────────────────────────────────────────

model TaskComment {
  id        String    @id @default(cuid())
  taskId    String
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User      @relation("TaskComments", fields: [authorId], references: [id])
  content   String    @db.Text
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([taskId])
  @@map("task_comments")
}

// ─── Task Attachments ─────────────────────────────────────────────────────────

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation("TaskAttachments", fields: [uploadedById], references: [id])
  filename     String   @db.VarChar(500)
  mimeType     String   @db.VarChar(100)
  sizeBytes    Int
  storageKey   String   @db.VarChar(1000)
  createdAt    DateTime @default(now())

  @@index([taskId])
  @@map("task_attachments")
}

// =============================================================================
// CALENDAR, MEETINGS & EVENTS (v0.9.0)
// =============================================================================

// ─── Enums ────────────────────────────────────────────────────────────────────

enum CalendarScope {
  PERSONAL
  TEAM
  DEPARTMENT
  MINISTRY
  PROVINCE
  NATIONAL
}

enum EventStatus {
  TENTATIVE
  CONFIRMED
  CANCELLED
}

enum MeetingStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  POSTPONED
}

enum MeetingType {
  REGULAR
  EMERGENCY
  CABINET
  MINISTERIAL
  COMMITTEE
  WORKING_GROUP
  BILATERAL
  TRILATERAL
  VIRTUAL
  HYBRID
}

enum MeetingClassification {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  SECRET
}

enum ParticipantRole {
  ORGANIZER
  REQUIRED
  OPTIONAL
  PRESENTER
  OBSERVER
  SECRETARY
}

enum RsvpStatus {
  PENDING
  ACCEPTED
  DECLINED
  TENTATIVE
  DELEGATED
}

enum AttendanceStatus {
  ABSENT
  PRESENT
  LATE
  EXCUSED
  DELEGATED
}

// v1.5.0 — Prinodia Meet enums
enum LiveMeetRole {
  HOST
  CO_HOST
  PRESENTER
  PARTICIPANT
  GUEST
}

enum RecordingStatus {
  PENDING
  RECORDING
  PROCESSING
  READY
  FAILED
}

enum PollStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum BreakoutStatus {
  OPEN
  CLOSED
}

enum TranscriptStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum ResourceType {
  MEETING_ROOM
  PROJECTOR
  VEHICLE
  FACILITY
  EQUIPMENT
}

enum ReminderChannel {
  IN_APP
  EMAIL
  SMS
}

// ─── Recurring Rule ───────────────────────────────────────────────────────────

model RecurringRule {
  id          String              @id @default(cuid())
  frequency   RecurrenceFrequency
  interval    Int                 @default(1) // every N freq units
  daysOfWeek  Int[]               @default([]) // 0=Sun … 6=Sat
  dayOfMonth  Int? // 1-31
  monthOfYear Int? // 1-12
  untilDate   DateTime?
  occurrences Int? // max occurrences
  events      CalendarEvent[]
  createdAt   DateTime            @default(now())

  @@map("recurring_rules")
}

// ─── Calendar Event ───────────────────────────────────────────────────────────

model CalendarEvent {
  id               String                @id @default(cuid())
  title            String                @db.VarChar(500)
  description      String?               @db.Text
  location         String?               @db.VarChar(500)
  onlineMeetingUrl String?               @db.VarChar(2000)
  startAt          DateTime
  endAt            DateTime
  allDay           Boolean               @default(false)
  timezone         String                @default("Africa/Kinshasa") @db.VarChar(100)
  status           EventStatus           @default(CONFIRMED)
  scope            CalendarScope         @default(PERSONAL)
  classification   MeetingClassification @default(INTERNAL)
  color            String?               @db.VarChar(20) // hex color for UI

  // Owner / organizer
  createdById String
  createdBy   User   @relation("CreatedEvents", fields: [createdById], references: [id])

  // Scoping relations (optional — set for team/dept/ministry/province events)
  ministryId   String?
  ministry     Ministry?   @relation(fields: [ministryId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  divisionId   String?
  division     Division?   @relation(fields: [divisionId], references: [id])
  provinceId   String?
  province     Province?   @relation(fields: [provinceId], references: [id])

  // Recurrence
  recurringRuleId String?
  recurringRule   RecurringRule?  @relation(fields: [recurringRuleId], references: [id])
  parentEventId   String? // for exception instances of a recurrence
  parentEvent     CalendarEvent?  @relation("RecurringInstances", fields: [parentEventId], references: [id])
  instances       CalendarEvent[] @relation("RecurringInstances")

  // Linked meeting (when event IS a meeting)
  meeting Meeting?

  // Reminders
  reminders EventReminder[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([createdById])
  @@index([startAt, endAt])
  @@index([ministryId])
  @@index([departmentId])
  @@index([provinceId])
  @@index([scope])
  @@index([status])
  @@map("calendar_events")
}

// ─── Event Reminder ───────────────────────────────────────────────────────────

model EventReminder {
  id            String          @id @default(cuid())
  eventId       String
  event         CalendarEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId        String
  user          User            @relation("EventReminders", fields: [userId], references: [id])
  minutesBefore Int // 15, 60, 1440 (24h), etc.
  channel       ReminderChannel @default(IN_APP)
  sentAt        DateTime?
  createdAt     DateTime        @default(now())

  @@index([eventId])
  @@index([userId])
  @@index([sentAt])
  @@map("event_reminders")
}

// ─── Meeting ──────────────────────────────────────────────────────────────────

model Meeting {
  id               String                @id @default(cuid())
  eventId          String                @unique
  event            CalendarEvent         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  title            String                @db.VarChar(500)
  description      String?               @db.Text
  location         String?               @db.VarChar(500)
  onlineMeetingUrl String?               @db.VarChar(2000)
  meetingType      MeetingType           @default(REGULAR)
  status           MeetingStatus         @default(SCHEDULED)
  classification   MeetingClassification @default(INTERNAL)

  // Organizer
  organizerId String
  organizer   User   @relation("OrganizedMeetings", fields: [organizerId], references: [id])

  // Room booking
  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id])

  // Linked document (meeting brief, for reference)
  briefDocumentId String?

  // Participants
  participants MeetingParticipant[]

  // Agenda
  agendaItems MeetingAgendaItem[]

  // Minutes
  minutes MeetingMinutes?

  // Action items (tasks generated from meeting)
  actionItems MeetingActionItem[]

  // Attachments
  attachments MeetingAttachment[]

  // Workflow for approval (e.g. minutes approval)
  workflowInstanceId String?

  // Cabinet session link (v1.0.0)
  cabinetSession CabinetSession?

  metadata     Json      @default("{}")
  cancelledAt  DateTime?
  cancelReason String?   @db.Text
  completedAt  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // v1.5.0 — Prinodia Meet live session fields
  channelId          String?              @unique // linked Chat channel for meeting chat
  channel            Channel?             @relation("MeetingChannel", fields: [channelId], references: [id])
  joinToken          String?              @unique @db.VarChar(128)
  isLocked           Boolean              @default(false)
  waitingRoomEnabled Boolean              @default(true)
  maxParticipants    Int?
  recordingEnabled   Boolean              @default(false)
  videoEnabled       Boolean              @default(true)
  audioEnabled       Boolean              @default(true)
  screenShareEnabled Boolean              @default(true)
  liveStartedAt      DateTime?
  liveEndedAt        DateTime?
  // v1.5.0 relations
  sessions           MeetingSession[]
  recordings         MeetingRecording[]
  transcripts        MeetingTranscript[]
  summaries          MeetingSummary[]
  polls              MeetingPoll[]
  breakoutRooms      MeetingBreakoutRoom[]
  reactions          MeetingReaction[]
  invites            MeetingInvite[]

  @@index([organizerId])
  @@index([status])
  @@index([meetingType])
  @@index([roomId])
  @@index([channelId])
  @@map("meetings")
}

// ─── Meeting Participant ──────────────────────────────────────────────────────

model MeetingParticipant {
  id               String            @id @default(cuid())
  meetingId        String
  meeting          Meeting           @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId           String
  user             User              @relation("MeetingParticipations", fields: [userId], references: [id])
  role             ParticipantRole   @default(REQUIRED)
  rsvpStatus       RsvpStatus        @default(PENDING)
  attendanceStatus AttendanceStatus?
  rsvpAt           DateTime?
  delegatedToId    String?
  delegatedTo      User?             @relation("DelegatedParticipations", fields: [delegatedToId], references: [id])
  reminderSentAt   DateTime?
  note             String?           @db.VarChar(500)
  // v1.5.0 — live session state
  liveRole          LiveMeetRole     @default(PARTICIPANT)
  joinedAt          DateTime?
  leftAt            DateTime?
  isAudioMuted      Boolean          @default(false)
  isVideoOff        Boolean          @default(false)
  isHandRaised      Boolean          @default(false)
  isInWaitingRoom   Boolean          @default(false)
  connectionQuality String?          @db.VarChar(20)
  deviceInfo        Json             @default("{}")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
  @@index([rsvpStatus])
  @@map("meeting_participants")
}

// ─── Meeting Agenda Item ──────────────────────────────────────────────────────

model MeetingAgendaItem {
  id               String   @id @default(cuid())
  meetingId        String
  meeting          Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  order            Int
  title            String   @db.VarChar(500)
  description      String?  @db.Text
  presenterId      String?
  presenter        User?    @relation("AgendaPresenters", fields: [presenterId], references: [id])
  durationMinutes  Int?
  supportingDocs   String[] @default([]) // document IDs
  expectedDecision String?  @db.Text
  completed        Boolean  @default(false)
  notes            String?  @db.Text // minutes for this item
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([meetingId])
  @@map("meeting_agenda_items")
}

// ─── Meeting Minutes ──────────────────────────────────────────────────────────

model MeetingMinutes {
  id                 String    @id @default(cuid())
  meetingId          String    @unique
  meeting            Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  documentId         String?   @unique // linked GovSphere Writer document
  authorId           String
  author             User      @relation("MeetingMinutesAuthor", fields: [authorId], references: [id])
  content            String?   @db.Text // rich text fallback when no document
  isDraft            Boolean   @default(true)
  publishedAt        DateTime?
  publishedById      String?
  publishedBy        User?     @relation("MeetingMinutesPublisher", fields: [publishedById], references: [id])
  workflowInstanceId String? // minutes approval workflow
  versionHistory     Json      @default("[]")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([meetingId])
  @@map("meeting_minutes")
}

// ─── Meeting Action Item ──────────────────────────────────────────────────────

model MeetingActionItem {
  id           String   @id @default(cuid())
  meetingId    String
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  taskId       String   @unique // linked Task
  task         Task     @relation(fields: [taskId], references: [id])
  agendaItemId String?
  sourceNote   String?  @db.VarChar(1000)
  createdAt    DateTime @default(now())

  @@index([meetingId])
  @@map("meeting_action_items")
}

// ─── Meeting Attachment ───────────────────────────────────────────────────────

model MeetingAttachment {
  id           String   @id @default(cuid())
  meetingId    String
  meeting      Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation("MeetingAttachments", fields: [uploadedById], references: [id])
  filename     String   @db.VarChar(500)
  mimeType     String   @db.VarChar(100)
  sizeBytes    Int
  storageKey   String   @db.VarChar(1000)
  documentId   String? // linked GovSphere document (if applicable)
  createdAt    DateTime @default(now())

  @@index([meetingId])
  @@map("meeting_attachments")
}

// ─── Room / Resource ──────────────────────────────────────────────────────────

model Room {
  id          String        @id @default(cuid())
  name        String        @db.VarChar(200)
  code        String?       @db.VarChar(50) // e.g. "SALLE-A", "VEH-01"
  type        ResourceType  @default(MEETING_ROOM)
  capacity    Int?
  location    String?       @db.VarChar(500)
  description String?       @db.Text
  amenities   String[]      @default([]) // "projector", "whiteboard", etc.
  ministryId  String?
  ministry    Ministry?     @relation(fields: [ministryId], references: [id])
  isActive    Boolean       @default(true)
  bookings    RoomBooking[]
  meetings    Meeting[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([ministryId])
  @@index([type])
  @@map("rooms")
}

// ─── Room Booking ─────────────────────────────────────────────────────────────

model RoomBooking {
  id          String    @id @default(cuid())
  roomId      String
  room        Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bookedById  String
  bookedBy    User      @relation("RoomBookings", fields: [bookedById], references: [id])
  startAt     DateTime
  endAt       DateTime
  purpose     String?   @db.VarChar(500)
  eventId     String? // linked calendar event
  cancelledAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([roomId, startAt, endAt])
  @@index([bookedById])
  @@map("room_bookings")
}

// =============================================================================
// PRINODIA MEET — LIVE MEETING MODELS (v1.5.0)
// =============================================================================

// ─── Meeting Session ──────────────────────────────────────────────────────────

model MeetingSession {
  id                   String    @id @default(cuid())
  meetingId            String
  meeting              Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  hostId               String
  host                 User      @relation("MeetSessionHost", fields: [hostId], references: [id])
  startedAt            DateTime  @default(now())
  endedAt              DateTime?
  durationSeconds      Int?
  participantCount     Int       @default(0)
  peakParticipantCount Int       @default(0)
  roomSid              String?   @db.VarChar(500) // future: LiveKit / Twilio room SID
  metadata             Json      @default("{}")
  createdAt            DateTime  @default(now())

  @@index([meetingId])
  @@index([hostId])
  @@map("meeting_sessions")
}

// ─── Meeting Recording ────────────────────────────────────────────────────────

model MeetingRecording {
  id              String           @id @default(cuid())
  meetingId       String
  meeting         Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  startedById     String
  startedBy       User             @relation("MeetRecordingStarter", fields: [startedById], references: [id])
  status          RecordingStatus  @default(PENDING)
  storageKey      String?          @db.VarChar(1000)
  filename        String?          @db.VarChar(500)
  durationSeconds Int?
  sizeBytes       BigInt?
  mimeType        String?          @db.VarChar(100)
  startedAt       DateTime         @default(now())
  stoppedAt       DateTime?
  processedAt     DateTime?
  downloadUrl     String?          @db.VarChar(2000)
  expiresAt       DateTime?
  metadata        Json             @default("{}")
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  transcripts MeetingTranscript[]

  @@index([meetingId])
  @@index([status])
  @@map("meeting_recordings")
}

// ─── Meeting Transcript ───────────────────────────────────────────────────────

model MeetingTranscript {
  id          String            @id @default(cuid())
  meetingId   String
  meeting     Meeting           @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  recordingId String?
  recording   MeetingRecording? @relation(fields: [recordingId], references: [id])
  status      TranscriptStatus  @default(IN_PROGRESS)
  content     String?           @db.Text
  segments    Json              @default("[]") // [{speakerId, text, startMs, endMs}]
  language    String            @default("fr") @db.VarChar(10)
  generatedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([meetingId])
  @@map("meeting_transcripts")
}

// ─── Meeting Summary ─────────────────────────────────────────────────────────

model MeetingSummary {
  id          String   @id @default(cuid())
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  authorId    String?  // null = AI-generated
  author      User?    @relation("MeetSummaryAuthor", fields: [authorId], references: [id])
  overview    String?  @db.Text
  decisions   Json     @default("[]") // [{text, madeBy}]
  actionItems Json     @default("[]") // [{text, assigneeId, dueDate}]
  keyPoints   Json     @default("[]") // [string]
  nextSteps   String?  @db.Text
  aiGenerated Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([meetingId])
  @@map("meeting_summaries")
}

// ─── Meeting Poll ─────────────────────────────────────────────────────────────

model MeetingPoll {
  id            String     @id @default(cuid())
  meetingId     String
  meeting       Meeting    @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdById   String
  createdBy     User       @relation("MeetPollCreator", fields: [createdById], references: [id])
  question      String     @db.VarChar(1000)
  status        PollStatus @default(DRAFT)
  isAnonymous   Boolean    @default(false)
  allowMultiple Boolean    @default(false)
  startedAt     DateTime?
  closedAt      DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  options MeetingPollOption[]
  votes   MeetingPollVote[]

  @@index([meetingId])
  @@map("meeting_polls")
}

// ─── Meeting Poll Option ──────────────────────────────────────────────────────

model MeetingPollOption {
  id     String            @id @default(cuid())
  pollId String
  poll   MeetingPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  text   String            @db.VarChar(500)
  order  Int
  votes  MeetingPollVote[]

  @@index([pollId])
  @@map("meeting_poll_options")
}

// ─── Meeting Poll Vote ────────────────────────────────────────────────────────

model MeetingPollVote {
  id       String            @id @default(cuid())
  pollId   String
  poll     MeetingPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  optionId String
  option   MeetingPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  userId   String
  user     User              @relation("MeetPollVotes", fields: [userId], references: [id])
  votedAt  DateTime          @default(now())

  @@unique([pollId, optionId, userId])
  @@index([pollId])
  @@map("meeting_poll_votes")
}

// ─── Meeting Breakout Room ────────────────────────────────────────────────────

model MeetingBreakoutRoom {
  id        String         @id @default(cuid())
  meetingId String
  meeting   Meeting        @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  name      String         @db.VarChar(200)
  capacity  Int?
  status    BreakoutStatus @default(OPEN)
  openedAt  DateTime       @default(now())
  closedAt  DateTime?

  participants MeetingBreakoutRoomParticipant[]

  @@index([meetingId])
  @@map("meeting_breakout_rooms")
}

// ─── Meeting Breakout Room Participant ────────────────────────────────────────

model MeetingBreakoutRoomParticipant {
  id       String              @id @default(cuid())
  roomId   String
  room     MeetingBreakoutRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId   String
  user     User                @relation("BreakoutParticipant", fields: [userId], references: [id])
  joinedAt DateTime            @default(now())
  leftAt   DateTime?

  @@unique([roomId, userId])
  @@index([roomId])
  @@map("meeting_breakout_room_participants")
}

// ─── Meeting Reaction ─────────────────────────────────────────────────────────

model MeetingReaction {
  id        String   @id @default(cuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("MeetReactions", fields: [userId], references: [id])
  emoji     String   @db.VarChar(10)
  createdAt DateTime @default(now())

  @@index([meetingId])
  @@index([userId])
  @@map("meeting_reactions")
}

// ─── Meeting Invite ───────────────────────────────────────────────────────────

model MeetingInvite {
  id          String    @id @default(cuid())
  meetingId   String
  meeting     Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User      @relation("MeetInvites", fields: [createdById], references: [id])
  token       String    @unique @default(cuid())
  email       String?   @db.VarChar(500) // targeted invite (optional)
  maxUses     Int?
  uses        Int       @default(0)
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([meetingId])
  @@index([token])
  @@map("meeting_invites")
}

// =============================================================================
// EXECUTIVE OFFICE & CABINET MANAGEMENT (v1.0.0)
// =============================================================================

// ─── Enums ────────────────────────────────────────────────────────────────────

enum ExecutiveOfficeType {
  PRESIDENCY
  PRIME_MINISTER_OFFICE
  CABINET_SECRETARIAT
  MINISTERIAL
  DEPUTY_MINISTERIAL
  PERMANENT_SECRETARY_OFFICE
  CHIEF_OF_STAFF_OFFICE
  EXECUTIVE_ASSISTANT_OFFICE
}

enum CabinetSessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DecisionStatus {
  DRAFT
  UNDER_REVIEW
  ADOPTED
  REJECTED
  DEFERRED
  WITHDRAWN
}

enum DecisionPriority {
  URGENT
  HIGH
  NORMAL
  LOW
}

enum ImplementationStatus {
  NOT_STARTED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  OVERDUE
}

enum BriefingType {
  DAILY
  WEEKLY
  CABINET
  EMERGENCY
  SPECIAL
}

enum BriefingStatus {
  DRAFT
  REVIEW
  APPROVED
  DISTRIBUTED
}

enum CorrespondenceType {
  OFFICIAL_LETTER
  PRESIDENTIAL_DIRECTIVE
  MINISTERIAL_MEMO
  CABINET_CIRCULAR
  EXECUTIVE_NOTE
  COMMUNIQUE
}

enum CorrespondenceClassification {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  SECRET
  TOP_SECRET
}

enum AnnouncementAudience {
  ALL_STAFF
  MINISTERS
  DIRECTORS
  CABINET_MEMBERS
  SPECIFIC_MINISTRY
  PUBLIC
}

// ─── Executive Office ─────────────────────────────────────────────────────────

model ExecutiveOffice {
  id          String              @id @default(cuid())
  name        String              @db.VarChar(255)
  officeType  ExecutiveOfficeType
  code        String              @unique @db.VarChar(50)
  description String?             @db.Text
  location    String?             @db.VarChar(500)
  isActive    Boolean             @default(true)

  // Head of office
  headId String?
  head   User?   @relation("ExecutiveOfficeHead", fields: [headId], references: [id])

  // Linked to ministry (for ministerial offices)
  ministryId String?
  ministry   Ministry? @relation(fields: [ministryId], references: [id])

  // Relations
  staff          ExecutiveOfficeStaff[]
  briefings      ExecutiveBriefing[]
  correspondence ExecutiveCorrespondence[]
  announcements  ExecutiveAnnouncement[]

  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([officeType])
  @@index([headId])
  @@index([ministryId])
  @@map("executive_offices")
}

model ExecutiveOfficeStaff {
  id        String          @id @default(cuid())
  officeId  String
  office    ExecutiveOffice @relation(fields: [officeId], references: [id], onDelete: Cascade)
  userId    String
  user      User            @relation("ExecutiveOfficeStaff", fields: [userId], references: [id])
  title     String?         @db.VarChar(255)
  isPrimary Boolean         @default(false)
  startDate DateTime        @default(now())
  endDate   DateTime?
  createdAt DateTime        @default(now())

  @@unique([officeId, userId])
  @@index([officeId])
  @@index([userId])
  @@map("executive_office_staff")
}

// ─── Cabinet Session ──────────────────────────────────────────────────────────

model CabinetSession {
  id            String               @id @default(cuid())
  sessionNumber Int
  title         String               @db.VarChar(500)
  description   String?              @db.Text
  status        CabinetSessionStatus @default(SCHEDULED)
  location      String?              @db.VarChar(500)
  scheduledAt   DateTime
  startedAt     DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  cancelReason  String?              @db.Text

  // Chaired by
  chairId String
  chair   User   @relation("CabinetChair", fields: [chairId], references: [id])

  // Secretary
  secretaryId String?
  secretary   User?   @relation("CabinetSecretary", fields: [secretaryId], references: [id])

  // Linked meeting (for scheduling + attendance)
  meetingId String?  @unique
  meeting   Meeting? @relation(fields: [meetingId], references: [id])

  // Sub-relations
  agendaItems CabinetAgendaItem[]
  decisions   CabinetDecision[]

  // Minutes document
  minutesDocumentId String?

  metadata    Json     @default("{}")
  createdById String
  createdBy   User     @relation("CabinetSessionCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([scheduledAt])
  @@index([chairId])
  @@map("cabinet_sessions")
}

// ─── Cabinet Agenda Item ──────────────────────────────────────────────────────

model CabinetAgendaItem {
  id              String            @id @default(cuid())
  sessionId       String
  session         CabinetSession    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  order           Int
  title           String            @db.VarChar(500)
  description     String?           @db.Text
  presentedById   String?
  presentedBy     User?             @relation("CabinetAgendaPresenters", fields: [presentedById], references: [id])
  durationMinutes Int?
  supportingDocs  String[]          @default([]) // document IDs
  completed       Boolean           @default(false)
  notes           String?           @db.Text
  decisions       CabinetDecision[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([sessionId])
  @@map("cabinet_agenda_items")
}

// ─── Cabinet Decision ─────────────────────────────────────────────────────────

model CabinetDecision {
  id             String             @id @default(cuid())
  decisionNumber String             @unique @db.VarChar(100) // e.g. "DEC-2026-001"
  sessionId      String
  session        CabinetSession     @relation(fields: [sessionId], references: [id])
  agendaItemId   String?
  agendaItem     CabinetAgendaItem? @relation(fields: [agendaItemId], references: [id])
  title          String             @db.VarChar(500)
  content        String             @db.Text
  status         DecisionStatus     @default(DRAFT)
  priority       DecisionPriority   @default(NORMAL)

  // Voting
  votesFor     Int     @default(0)
  votesAgainst Int     @default(0)
  abstentions  Int     @default(0)
  votingNotes  String? @db.Text

  // Responsible ministry
  responsibleMinistryId String?
  responsibleMinistry   Ministry? @relation(fields: [responsibleMinistryId], references: [id])

  // Owner
  ownerId String?
  owner   User?   @relation("DecisionOwners", fields: [ownerId], references: [id])

  // Deadlines
  dueDate     DateTime?
  adoptedAt   DateTime?
  adoptedById String?
  adoptedBy   User?     @relation("DecisionAdoptedBy", fields: [adoptedById], references: [id])

  // Linked document (official decision record)
  documentId String?

  // Linked workflow for implementation
  workflowInstanceId String?

  // Implementation tracking
  implementations DecisionImplementation[]

  // Tags
  tags String[] @default([])

  metadata    Json     @default("{}")
  createdById String
  createdBy   User     @relation("DecisionCreators", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sessionId])
  @@index([status])
  @@index([priority])
  @@index([responsibleMinistryId])
  @@index([dueDate])
  @@map("cabinet_decisions")
}

// ─── Decision Implementation ──────────────────────────────────────────────────

model DecisionImplementation {
  id           String               @id @default(cuid())
  decisionId   String
  decision     CabinetDecision      @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  title        String               @db.VarChar(500)
  description  String?              @db.Text
  status       ImplementationStatus @default(NOT_STARTED)
  progressPct  Int                  @default(0) // 0-100
  assignedToId String?
  assignedTo   User?                @relation("ImplementationAssignees", fields: [assignedToId], references: [id])
  ministryId   String?
  ministry     Ministry?            @relation(fields: [ministryId], references: [id])
  dueDate      DateTime?
  completedAt  DateTime?
  evidence     String?              @db.Text
  notes        String?              @db.Text

  // Linked task
  taskId String? @unique
  task   Task?   @relation(fields: [taskId], references: [id])

  // Linked workflow
  workflowInstanceId String?

  createdById String
  createdBy   User     @relation("ImplementationCreators", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([decisionId])
  @@index([status])
  @@index([assignedToId])
  @@index([ministryId])
  @@map("decision_implementations")
}

// ─── Executive Briefing ───────────────────────────────────────────────────────

model ExecutiveBriefing {
  id           String         @id @default(cuid())
  title        String         @db.VarChar(500)
  briefingType BriefingType
  status       BriefingStatus @default(DRAFT)
  content      Json           @default("{}") // rich text (TipTap JSON)
  summary      String?        @db.Text
  scheduledFor DateTime?
  publishedAt  DateTime?
  approvedAt   DateTime?

  // Office that creates/owns the briefing
  officeId String?
  office   ExecutiveOffice? @relation(fields: [officeId], references: [id])

  // Author
  authorId String
  author   User   @relation("BriefingAuthors", fields: [authorId], references: [id])

  // Approver
  approvedById String?
  approvedBy   User?   @relation("BriefingApprovers", fields: [approvedById], references: [id])

  // Linked documents
  attachments String[] @default([]) // document IDs
  // Linked meetings
  meetingRefs String[] @default([]) // meeting IDs

  // Workflow for approval
  workflowInstanceId String?

  // Version history
  versionHistory Json @default("[]")

  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([briefingType])
  @@index([status])
  @@index([scheduledFor])
  @@index([authorId])
  @@map("executive_briefings")
}

// ─── Executive Correspondence ─────────────────────────────────────────────────

model ExecutiveCorrespondence {
  id                 String                       @id @default(cuid())
  referenceNumber    String                       @unique @db.VarChar(100) // e.g. "REF-2026-001"
  subject            String                       @db.VarChar(500)
  correspondenceType CorrespondenceType
  classification     CorrespondenceClassification @default(INTERNAL)
  content            Json                         @default("{}") // rich text
  summary            String?                      @db.Text

  // Sender
  fromOfficeId String?
  fromOffice   ExecutiveOffice? @relation(fields: [fromOfficeId], references: [id])
  fromUserId   String
  fromUser     User             @relation("CorrespondenceSenders", fields: [fromUserId], references: [id])

  // Recipient
  toMinistryId String?
  toMinistry   Ministry? @relation(fields: [toMinistryId], references: [id])
  toUserId     String?
  toUser       User?     @relation("CorrespondenceRecipients", fields: [toUserId], references: [id])
  toExternal   String?   @db.VarChar(500) // external recipient name/email

  // Status tracking
  sentAt         DateTime?
  receivedAt     DateTime?
  acknowledgedAt DateTime?

  // Linked document
  documentId String?

  // Attachments
  attachments String[] @default([]) // document IDs

  // Workflow
  workflowInstanceId String?

  // Reply chain
  parentCorrespondenceId String?
  parentCorrespondence   ExecutiveCorrespondence?  @relation("CorrespondenceReplies", fields: [parentCorrespondenceId], references: [id])
  replies                ExecutiveCorrespondence[] @relation("CorrespondenceReplies")

  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([correspondenceType])
  @@index([classification])
  @@index([fromUserId])
  @@index([toMinistryId])
  @@index([sentAt])
  @@map("executive_correspondence")
}

// ─── Executive Announcement ───────────────────────────────────────────────────

model ExecutiveAnnouncement {
  id          String               @id @default(cuid())
  title       String               @db.VarChar(500)
  content     String               @db.Text
  audience    AnnouncementAudience @default(ALL_STAFF)
  isPublished Boolean              @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?

  // Publishing office
  officeId String?
  office   ExecutiveOffice? @relation(fields: [officeId], references: [id])

  // Author
  authorId String
  author   User   @relation("AnnouncementAuthors", fields: [authorId], references: [id])

  // Target ministry (when audience = SPECIFIC_MINISTRY)
  targetMinistryId String?
  targetMinistry   Ministry? @relation(fields: [targetMinistryId], references: [id])

  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([audience])
  @@index([isPublished])
  @@index([publishedAt])
  @@index([officeId])
  @@map("executive_announcements")
}

// =============================================================================
// ORGANIZATIONS — Neutral parent model (v1.0.2)
// Supports: GOVERNMENT, ENTERPRISE, EDUCATION, HEALTHCARE, NGO, CHURCH, etc.
// Backward-compatible: existing Ministry/Department/User data unaffected.
// =============================================================================

enum OrganizationType {
  GOVERNMENT
  ENTERPRISE
  EDUCATION
  HEALTHCARE
  NGO
  CHURCH
  NON_PROFIT
  OTHER
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  ARCHIVED
  PENDING_VERIFICATION // Government/regulated orgs awaiting admin approval
}

// =============================================================================
// REALTIME — v1.2.0 Real-Time Collaboration Core
// =============================================================================

/// Tracks active WebSocket connections per user per device.
/// Ephemeral — rows are created on connect and deleted on disconnect.
/// Multiple rows per user allowed (multi-device, multi-tab).
model UserConnection {
  id              String     @id @default(cuid())
  userId          String
  user            User       @relation("UserConnections", fields: [userId], references: [id], onDelete: Cascade)
  socketId        String     @unique @db.VarChar(100)
  deviceType      DeviceType @default(WEB)
  userAgent       String?    @db.VarChar(500)
  ipAddress       String?    @db.VarChar(45)
  connectedAt     DateTime   @default(now())
  lastHeartbeatAt DateTime   @default(now())

  @@index([userId])
  @@index([lastHeartbeatAt])
  @@map("user_connections")
}

/// Persistent activity feed for each organization.
/// Every significant action in the workspace is recorded here
/// and streamed to subscribed clients via WebSocket.
model ActivityEvent {
  id           String   @id @default(cuid())
  orgId        String
  organization Organization @relation("OrgActivityEvents", fields: [orgId], references: [id], onDelete: Cascade)
  actorId      String
  actor        User     @relation("UserActivityEvents", fields: [actorId], references: [id])
  eventType    String   @db.VarChar(100)   // e.g. "MessageSent", "DocumentCreated"
  resourceType String   @db.VarChar(100)   // e.g. "message", "document", "task"
  resourceId   String   @db.VarChar(100)   // the ID of the resource that changed
  summary      String   @db.VarChar(500)   // human-readable: "John uploaded a document"
  metadata     Json     @default("{}")
  createdAt    DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([actorId, createdAt])
  @@index([eventType, createdAt])
  @@map("activity_events")
}

model Organization {
  id             String             @id @default(cuid())
  name           String             @db.VarChar(255)
  code           String             @unique @db.VarChar(50)
  // URL-safe slug for workspace URLs — e.g. "prinodia-technologies", "ministry-of-finance"
  // Unique across platform. Prepares for: app.prinodia.com/workspace/<slug>
  workspaceSlug  String?            @unique @db.VarChar(120)
  type           OrganizationType
  status         OrganizationStatus @default(ACTIVE)
  description    String?            @db.Text
  email          String?            @db.VarChar(255)
  phone          String?            @db.VarChar(50)
  website        String?            @db.VarChar(255)
  address        String?            @db.VarChar(500)
  city           String?            @db.VarChar(100)
  country        String?            @db.VarChar(100)
  logoUrl        String?            @db.VarChar(500)
  isDemo         Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  // Reverse relations
  ministries     Ministry[]      @relation("OrganizationMinistries")
  departments    Department[]    @relation("OrganizationDepartments")
  users          User[]          @relation("OrganizationUsers")
  activityEvents ActivityEvent[] @relation("OrgActivityEvents") // v1.2.0
  channels       Channel[]       @relation("ChannelOrganization") // v1.4.0

  @@index([type])
  @@index([status])
  @@index([isDemo])
  @@map("organizations")
}

// =============================================================================
// DEMO REGISTRY — Tracks all demo-generated entity IDs for safe reset (v1.1.0)
// =============================================================================

model DemoRegistry {
  id         String   @id @default(cuid())
  entityType String   @db.VarChar(100)
  entityId   String   @db.VarChar(100)
  sessionId  String   @db.VarChar(100)
  createdAt  DateTime @default(now())

  @@unique([entityType, entityId])
  @@index([sessionId])
  @@index([entityType])
  @@map("demo_registry")
}

// =============================================================================
// PRINODIA PEOPLE — v1.3.0
// Additive models. No existing models are modified.
// =============================================================================

// ─── Enums ───────────────────────────────────────────────────────────────────

enum OrgNodeType {
  ORGANIZATION
  DIVISION
  DEPARTMENT
  TEAM
  CUSTOM
}

enum WorkloadStatus {
  NOT_ASSIGNED
  AVAILABLE
  NORMAL
  BUSY
  OVERLOADED
}

enum VacationStatus {
  VACATION
  SICK_LEAVE
  REMOTE
  OFFICE
  TRAVEL
  TRAINING
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum SkillCategory {
  TECHNICAL
  DOMAIN
  SOFT
  LANGUAGE
  CERTIFICATION
}

// ─── OrgNode — Generic, recursive organizational hierarchy ───────────────────
// Additive: complements existing Ministry/Department/Division (government).
// Use for non-government orgs or cross-cutting teams.
// Uses adjacency list + materializedPath for efficient subtree queries.

model OrgNode {
  id               String      @id @default(cuid())
  organizationId   String
  name             String      @db.VarChar(200)
  type             OrgNodeType @default(DEPARTMENT)
  parentId         String?
  // e.g. "/org-abc/div-xyz/dept-123/" — enables fast subtree: LIKE '/prefix/%'
  materializedPath String      @db.VarChar(1000)
  description      String?     @db.Text
  code             String?     @db.VarChar(50)
  color            String?     @db.VarChar(7)
  icon             String?     @db.VarChar(50)
  sortOrder        Int         @default(0)
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  parent           OrgNode?         @relation("OrgNodeTree", fields: [parentId], references: [id])
  children         OrgNode[]        @relation("OrgNodeTree")
  employees        EmployeeProfile[] @relation("EmployeePrimaryNode")

  @@index([organizationId])
  @@index([parentId])
  @@index([organizationId, materializedPath])
  @@index([isActive])
  @@map("org_nodes")
}

// ─── EmployeeProfile — Extended profile layered on top of User ────────────────
// 1-to-1 with User. Opt-in: not every User has a profile.
// Stores: bio, workload, availability, skills summary, org-node placement.

model EmployeeProfile {
  id             String         @id @default(cuid())
  userId         String         @unique
  organizationId String

  // Extended identity
  bio            String?        @db.Text
  phone          String?        @db.VarChar(50)
  mobile         String?        @db.VarChar(50)
  officeLocation String?        @db.VarChar(200)
  timeZone       String         @default("UTC") @db.VarChar(60)
  workingHours   Json?          // { mon:["08:00","17:00"], tue:["08:00","17:00"], ... }

  // Org placement (generic hierarchy)
  orgNodeId      String?
  // Secondary memberships stored as simple array of orgNode IDs
  secondaryOrgNodeIds String[]  @default([])

  // Workload & availability
  workloadStatus WorkloadStatus @default(AVAILABLE)
  vacationStatus VacationStatus?
  vacationFrom   DateTime?
  vacationUntil  DateTime?
  availabilityNote String?      @db.VarChar(200)

  // Languages: [{ code:"fr", level:"NATIVE" }, { code:"en", level:"PROFESSIONAL" }]
  languages      Json[]         @default([])

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  orgNode        OrgNode?       @relation("EmployeePrimaryNode", fields: [orgNodeId], references: [id])
  skills         EmployeeSkill[]

  @@index([organizationId])
  @@index([orgNodeId])
  @@index([workloadStatus])
  @@map("employee_profiles")
}

// ─── Skill catalog ────────────────────────────────────────────────────────────

model Skill {
  id          String        @id @default(cuid())
  name        String        @db.VarChar(100)
  slug        String        @unique @db.VarChar(100)
  category    SkillCategory @default(TECHNICAL)
  description String?       @db.Text
  icon        String?       @db.VarChar(50)
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  employees   EmployeeSkill[]

  @@index([category])
  @@index([isActive])
  @@map("skills")
}

// ─── Employee ↔ Skill junction ────────────────────────────────────────────────

model EmployeeSkill {
  id          String          @id @default(cuid())
  profileId   String
  skillId     String
  level       SkillLevel      @default(INTERMEDIATE)
  verified    Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  profile     EmployeeProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill       Skill           @relation(fields: [skillId], references: [id])

  @@unique([profileId, skillId])
  @@index([skillId, level])
  @@map("employee_skills")
}

// ═══════════════════════════════════════════════════════════════════════════════
// Prinodia Canvas v1.6.0
// Live collaborative workspace: whiteboards, diagrams, meeting boards,
// code collaboration, project visualization. Integrates with Meet, Chat,
// People, Documents, Workflow, Search, Realtime.
// ═══════════════════════════════════════════════════════════════════════════════

// ─── Canvas enums ─────────────────────────────────────────────────────────────

enum CanvasBoardType {
  WHITEBOARD
  MEETING_BOARD
  PROJECT_BOARD
  DOCUMENT_BOARD
  WORKFLOW_BOARD
  CODE_BOARD
  DIAGRAM_BOARD
  BRAINSTORM_BOARD
}

enum CanvasBoardStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum CanvasParticipantRole {
  OWNER
  EDITOR
  PRESENTER
  VIEWER
}

enum CanvasElementType {
  PENCIL_STROKE
  HIGHLIGHTER_STROKE
  TEXT
  STICKY_NOTE
  SHAPE
  CONNECTOR
  ARROW
  IMAGE
  PDF
  DOCUMENT_LINK
  CODE_BLOCK
  TABLE
  MIND_MAP_NODE
  FLOWCHART_NODE
  COMMENT_PIN
  LASER_POINTER
  SCREEN_ANNOTATION
}

enum CanvasExportFormat {
  PNG
  PDF
  SVG
  JSON
}

enum CanvasExportStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum CanvasShareAccess {
  VIEW
  EDIT
}

// ─── CanvasBoard ──────────────────────────────────────────────────────────────
// The root collaborative workspace entity. One board = one infinite canvas.

model CanvasBoard {
  id             String            @id @default(cuid())
  organizationId String
  ownerId        String
  title          String            @db.VarChar(200)
  description    String?           @db.Text
  boardType      CanvasBoardType   @default(WHITEBOARD)
  status         CanvasBoardStatus @default(ACTIVE)

  // Integrations (all optional)
  meetingId      String?           // linked Meeting (v0.9.0+)
  channelId      String?           // linked Chat channel (v1.4.0+)
  documentId     String?           // linked Document (v0.8.0+)
  workflowId     String?           // linked Workflow instance (v0.8.1+)
  templateId     String?           // created from CanvasTemplate

  // Canvas state
  thumbnailUrl   String?           @db.VarChar(500)
  viewportState  Json              @default("{}") // { x, y, zoom }
  background     String            @default("#FFFFFF") @db.VarChar(7)
  isPublic       Boolean           @default(false)
  isLocked       Boolean           @default(false)
  elementCount   Int               @default(0)
  lastActivityAt DateTime          @default(now())

  // AI extension point (v2.0.0)
  aiEnabled      Boolean           @default(false)
  aiContext      Json?

  // Drive extension point (v2.0.0)
  driveFileId    String?           @db.VarChar(200)

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?

  owner          User              @relation("CanvasBoardOwner", fields: [ownerId], references: [id])

  elements       CanvasElement[]
  participants   CanvasParticipant[]
  sessions       CanvasSession[]
  comments       CanvasComment[]
  exports        CanvasExport[]
  shares         CanvasShare[]
  presences      CanvasPresence[]
  activities     CanvasActivity[]

  @@index([organizationId])
  @@index([ownerId])
  @@index([boardType])
  @@index([status])
  @@index([meetingId])
  @@index([channelId])
  @@index([lastActivityAt])
  @@map("canvas_boards")
}

// ─── CanvasParticipant ────────────────────────────────────────────────────────

model CanvasParticipant {
  id        String                @id @default(cuid())
  boardId   String
  userId    String
  role      CanvasParticipantRole @default(VIEWER)
  invitedBy String?
  joinedAt  DateTime              @default(now())
  lastSeenAt DateTime?
  isActive  Boolean               @default(true)

  board     CanvasBoard           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user      User                  @relation("CanvasParticipations", fields: [userId], references: [id])

  @@unique([boardId, userId])
  @@index([userId])
  @@index([role])
  @@map("canvas_participants")
}

// ─── CanvasElement ────────────────────────────────────────────────────────────
// Every drawable object on the canvas.

model CanvasElement {
  id           String           @id @default(cuid())
  boardId      String
  createdBy    String
  elementType  CanvasElementType
  layerIndex   Int              @default(0)
  isLocked     Boolean          @default(false)
  isVisible    Boolean          @default(true)
  isDeleted    Boolean          @default(false)

  // Position & size (canvas coordinate space)
  x            Float            @default(0)
  y            Float            @default(0)
  width        Float?
  height       Float?
  rotation     Float            @default(0)

  // Type-specific data (flexible JSON payload)
  // TEXT: { text, fontSize, fontFamily, color, align, bold, italic }
  // STICKY_NOTE: { text, color, fontSize }
  // SHAPE: { shapeType:"rect|circle|triangle|diamond", fill, stroke, strokeWidth }
  // CONNECTOR/ARROW: { points:[{x,y}], startId, endId, arrowHead }
  // PENCIL_STROKE/HIGHLIGHTER_STROKE: { points:[{x,y,pressure}], color, width, opacity }
  // CODE_BLOCK: { language, content, readOnly, lineNumbers, theme }
  // IMAGE: { url, originalFilename, mimeType }
  // DOCUMENT_LINK: { documentId, title }
  // COMMENT_PIN: { commentId }
  // TABLE: { rows, cols, cells:[[]] }
  // MIND_MAP_NODE/FLOWCHART_NODE: { label, parentId, children:[] }
  data         Json             @default("{}")

  // Style overrides (merged with type defaults)
  style        Json             @default("{}")

  // Locking for concurrent editing
  lockedBy     String?
  lockedAt     DateTime?

  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  board        CanvasBoard      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  creator      User             @relation("CanvasElementCreator", fields: [createdBy], references: [id])
  versions     CanvasElementVersion[]
  comments     CanvasComment[]

  @@index([boardId])
  @@index([boardId, isDeleted])
  @@index([boardId, layerIndex])
  @@index([elementType])
  @@index([createdBy])
  @@map("canvas_elements")
}

// ─── CanvasElementVersion ─────────────────────────────────────────────────────
// Immutable snapshot of an element at each update — enables undo/redo history.

model CanvasElementVersion {
  id          String        @id @default(cuid())
  elementId   String
  editorId    String
  versionNum  Int
  data        Json          // full element snapshot at this point
  style       Json
  x           Float
  y           Float
  width       Float?
  height      Float?
  rotation    Float
  createdAt   DateTime      @default(now())

  element     CanvasElement @relation(fields: [elementId], references: [id], onDelete: Cascade)
  editor      User          @relation("CanvasVersionEditor", fields: [editorId], references: [id])

  @@index([elementId])
  @@index([elementId, versionNum])
  @@map("canvas_element_versions")
}

// ─── CanvasSession ────────────────────────────────────────────────────────────
// Tracks a collaborative editing session (from first join to all leave).

model CanvasSession {
  id               String      @id @default(cuid())
  boardId          String
  startedById      String
  startedAt        DateTime    @default(now())
  endedAt          DateTime?
  durationSeconds  Int?
  participantCount Int         @default(1)
  peakParticipants Int         @default(1)
  operationCount   Int         @default(0) // total element operations

  board            CanvasBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  startedBy        User        @relation("CanvasSessionStarter", fields: [startedById], references: [id])

  @@index([boardId])
  @@index([boardId, endedAt])
  @@map("canvas_sessions")
}

// ─── CanvasComment ────────────────────────────────────────────────────────────
// Threaded comments anchored to a board or a specific element.

model CanvasComment {
  id         String        @id @default(cuid())
  boardId    String
  elementId  String?       // null = board-level comment
  authorId   String
  parentId   String?       // null = root comment; non-null = reply
  content    String        @db.Text
  posX       Float?        // canvas position for pin-type comments
  posY       Float?
  isResolved Boolean       @default(false)
  resolvedBy String?
  resolvedAt DateTime?
  isDeleted  Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  board      CanvasBoard   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  element    CanvasElement? @relation(fields: [elementId], references: [id])
  author     User          @relation("CanvasCommentAuthor", fields: [authorId], references: [id])
  parent     CanvasComment? @relation("CanvasCommentReplies", fields: [parentId], references: [id])
  replies    CanvasComment[] @relation("CanvasCommentReplies")

  @@index([boardId])
  @@index([elementId])
  @@index([authorId])
  @@index([boardId, isResolved])
  @@map("canvas_comments")
}

// ─── CanvasTemplate ───────────────────────────────────────────────────────────
// Reusable board templates (system-provided or user-created).

model CanvasTemplate {
  id             String          @id @default(cuid())
  organizationId String?         // null = global system template
  createdBy      String?
  name           String          @db.VarChar(200)
  description    String?         @db.Text
  boardType      CanvasBoardType @default(WHITEBOARD)
  thumbnailUrl   String?         @db.VarChar(500)
  isPublic       Boolean         @default(false)
  isSystem       Boolean         @default(false) // shipped with platform
  category       String?         @db.VarChar(100)
  tags           String[]        @default([])
  // Snapshot of elements to clone when creating from this template
  elementsSnapshot Json          @default("[]")
  useCount       Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  creator        User?           @relation("CanvasTemplateCreator", fields: [createdBy], references: [id])

  @@index([organizationId])
  @@index([boardType])
  @@index([isPublic, isSystem])
  @@map("canvas_templates")
}

// ─── CanvasExport ─────────────────────────────────────────────────────────────

model CanvasExport {
  id             String             @id @default(cuid())
  boardId        String
  requestedById  String
  format         CanvasExportFormat
  status         CanvasExportStatus @default(PENDING)
  downloadUrl    String?            @db.VarChar(500)
  fileSizeBytes  Int?
  pageRange      String?            @db.VarChar(50) // e.g. "1-5" for PDF
  options        Json               @default("{}") // { scale, quality, includeBackground }
  errorMessage   String?            @db.Text
  expiresAt      DateTime?
  processedAt    DateTime?
  createdAt      DateTime           @default(now())

  board          CanvasBoard        @relation(fields: [boardId], references: [id], onDelete: Cascade)
  requestedBy    User               @relation("CanvasExportRequester", fields: [requestedById], references: [id])

  @@index([boardId])
  @@index([requestedById])
  @@index([status])
  @@map("canvas_exports")
}

// ─── CanvasShare ──────────────────────────────────────────────────────────────
// Share links for external access (with optional expiry and password).

model CanvasShare {
  id          String           @id @default(cuid())
  boardId     String
  createdById String
  shareToken  String           @unique @db.VarChar(64)
  access      CanvasShareAccess @default(VIEW)
  label       String?          @db.VarChar(100)
  password    String?          @db.VarChar(200) // bcrypt hash
  maxUses     Int?
  uses        Int              @default(0)
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime         @default(now())

  board       CanvasBoard      @relation(fields: [boardId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("CanvasShareCreator", fields: [createdById], references: [id])

  @@index([boardId])
  @@index([shareToken])
  @@map("canvas_shares")
}

// ─── CanvasPresence ───────────────────────────────────────────────────────────
// Live cursor / presence state per user per board (Redis-backed in production;
// Postgres fallback for persistence & debug).

model CanvasPresence {
  id          String      @id @default(cuid())
  boardId     String
  userId      String
  socketId    String      @db.VarChar(100)
  cursorX     Float?
  cursorY     Float?
  viewportX   Float?
  viewportY   Float?
  zoom        Float       @default(1)
  isFollowing String?     // userId being followed (presenter mode)
  color       String      @db.VarChar(7) // assigned cursor color
  lastSeenAt  DateTime    @default(now())

  board       CanvasBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user        User        @relation("CanvasPresences", fields: [userId], references: [id])

  @@unique([boardId, userId])
  @@index([boardId])
  @@index([lastSeenAt])
  @@map("canvas_presences")
}

// ─── CanvasActivity ───────────────────────────────────────────────────────────
// Board-scoped activity feed (who did what, when).

model CanvasActivity {
  id          String      @id @default(cuid())
  boardId     String
  actorId     String
  eventType   String      @db.VarChar(80) // e.g. "element.created", "comment.added"
  elementId   String?
  summary     String      @db.VarChar(300)
  metadata    Json        @default("{}")
  occurredAt  DateTime    @default(now())

  board       CanvasBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  actor       User        @relation("CanvasActivities", fields: [actorId], references: [id])

  @@index([boardId])
  @@index([boardId, occurredAt])
  @@index([actorId])
  @@map("canvas_activities")
}

// ─── User back-relations for Canvas (v1.6.0) ─────────────────────────────────
// NOTE: The relation fields below are added to the User model via the back-relation
// declarations above. Prisma auto-generates them; no ALTER TABLE needed on users.
