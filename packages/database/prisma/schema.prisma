// GovSphere — Prisma Schema v6 (v0.8.0 — Documents & Writer Platform)
// Database: PostgreSQL 17
// ORM: Prisma 5
//
// Government of the Democratic Republic of Congo
// Secure internal collaboration platform

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  SUPER_ADMIN
  GOVERNMENT_ADMIN
  MINISTRY_ADMIN
  DEPARTMENT_ADMIN
  DIVISION_ADMIN
  TEAM_MANAGER
  EMPLOYEE
  GUEST
}

enum UserType {
  GOVERNMENT_EMPLOYEE
  MINISTER
  DIRECTOR
  DEPARTMENT_ADMIN
  IT_ADMINISTRATOR
  EXTERNAL_PARTNER
  GUEST
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  LOCKED
  DEACTIVATED
  ARCHIVED
}

enum ChannelType {
  PUBLIC
  PRIVATE
  ANNOUNCEMENT
  DIRECT
  GROUP
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
  REPLY
  FORWARDED
}

enum FileCategory {
  DOCUMENT
  IMAGE
  VIDEO
  AUDIO
  ARCHIVE
  OTHER
}

enum NotificationType {
  MESSAGE
  MENTION
  REACTION
  FILE_SHARED
  CHANNEL_INVITE
  TASK_ASSIGNED
  SYSTEM
}

