// Prinodia Workspace — Prisma Schema v8 (v1.0.2 — Organization Model Generalization)
// Database: PostgreSQL 17
// ORM: Prisma 5
//
// Multi-tenant platform supporting governments, enterprises, schools, hospitals, NGOs, and more.
// Backward-compatible: existing Ministry model preserved; Organizations added as the neutral parent.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

