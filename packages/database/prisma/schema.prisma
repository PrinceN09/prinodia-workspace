  POSITION_CREATED
  POSITION_UPDATED
  POSITION_DEACTIVATED
  EMPLOYEE_ASSIGNED
  EMPLOYEE_ASSIGNMENT_ENDED
  // Employee Lifecycle (v0.6.0)
  EMPLOYEE_INVITED
  EMPLOYEE_ACTIVATED
