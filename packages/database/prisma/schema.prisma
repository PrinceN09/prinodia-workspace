enum PresenceStatus {
  ONLINE
  AWAY
  BUSY
  DO_NOT_DISTURB
  OFFLINE
}

enum ConversationType {
  DIRECT // 1:1 DM
  GROUP  // multi-user group chat
}

// ─── Document enums (v0.8.0) ─────────────────────────────────────────────────

enum DocumentClassification {
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  SECRET
}

enum DocumentStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum DocumentType {
  MEMO
  REPORT
  CIRCULAR
  LETTER
  SPEECH
  DECREE
  DIRECTIVE
  NOTE
  OTHER
}

enum DocumentShareScope {
  USER
  MINISTRY
  DEPARTMENT
  DIVISION
}

enum DocumentExportFormat {
  PDF
  DOCX
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SupportedLanguage {
  fr
  en
  ln
  sw
  lua
}

enum MfaMethod {
  TOTP
  FIDO2
  BACKUP_CODE
}

enum FileStatus {
  PENDING
  READY
  REJECTED
}

// =============================================================================
// GOVERNMENT STRUCTURE
// =============================================================================

model Ministry {
  id               String       @id @default(cuid())
  name             String       @db.VarChar(255)
  nameTranslations Json         @default("{}")
  code             String       @unique @db.VarChar(50)
  description      String?      @db.Text
  logoUrl          String?      @db.VarChar(500)
  isActive         Boolean      @default(true)
  departments      Department[]
  positions        Position[]
  offices          Office[]
  users            User[]
  channels         Channel[]
  userRoles        UserRoleAssignment[]
  documents        Document[]
  documentShares   DocumentShare[]
  documentTemplates         DocumentTemplate[]
  workflowTemplates         WorkflowTemplate[]
  workflowDefinitions       WorkflowDefinition[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([code])
  @@map("ministries")
}

model Department {
  id               String     @id @default(cuid())
  ministryId       String
  ministry         Ministry   @relation(fields: [ministryId], references: [id])
  name             String     @db.VarChar(255)
  nameTranslations Json       @default("{}")
  code             String     @db.VarChar(50)
  description      String?    @db.Text
  isActive         Boolean    @default(true)
  divisions        Division[]
  positions        Position[]
  users            User[]
  channels         Channel[]
  userRoles        UserRoleAssignment[]
  documents        Document[]
  documentShares   DocumentShare[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([ministryId, code])
  @@index([ministryId])
  @@map("departments")
}

model Division {
  id               String     @id @default(cuid())
  departmentId     String
  department       Department @relation(fields: [departmentId], references: [id])
  name             String     @db.VarChar(255)
  nameTranslations Json       @default("{}")
  code             String     @db.VarChar(50)
  description      String?    @db.Text
  isActive         Boolean    @default(true)
  users            User[]
  userRoles        UserRoleAssignment[]
  positions        Position[]
  channels         Channel[]
  documents        Document[]
  documentShares   DocumentShare[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([departmentId, code])
  @@index([departmentId])
  @@map("divisions")
}

model Province {
  id               String    @id @default(cuid())
  name             String    @db.VarChar(255)
  nameTranslations Json      @default("{}")
  code             String    @unique @db.VarChar(10)
  capital          String?   @db.VarChar(255)
  isActive         Boolean   @default(true)
  offices          Office[]
  channels         Channel[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([code])
  @@map("provinces")
}

model Office {
  id          String     @id @default(cuid())
  provinceId  String
  province    Province   @relation(fields: [provinceId], references: [id])
  ministryId  String?
  ministry    Ministry?  @relation(fields: [ministryId], references: [id])
  name        String     @db.VarChar(255)
  code        String     @db.VarChar(50)
  address     String?    @db.Text
  isActive    Boolean    @default(true)
  positions   Position[]
  users       User[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([provinceId, code])
  @@index([provinceId])
  @@index([ministryId])
  @@map("offices")
}

enum PositionLevel {
  EXECUTIVE       // Minister, Secretary-General
  DIRECTOR        // Director-General, Director
  MANAGER         // Division Chief, Section Chief
  SPECIALIST      // Senior officer, Specialist
  OFFICER         // Standard civil servant
  SUPPORT         // Administrative support
}

model Position {
  id               String        @id @default(cuid())
  title            String        @db.VarChar(255)
  titleTranslations Json         @default("{}")
  code             String        @db.VarChar(50)
  level            PositionLevel @default(OFFICER)
  headcount        Int           @default(1)
  ministryId       String?
  ministry         Ministry?     @relation(fields: [ministryId], references: [id])
  departmentId     String?
  department       Department?   @relation(fields: [departmentId], references: [id])
  divisionId       String?
  division         Division?     @relation(fields: [divisionId], references: [id])
  officeId         String?
  office           Office?       @relation(fields: [officeId], references: [id])
  isActive         Boolean       @default(true)
  assignments      EmployeeAssignment[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([ministryId, code])
  @@index([ministryId])
  @@index([departmentId])
  @@index([divisionId])
  @@index([level])
  @@map("positions")
}

model EmployeeAssignment {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  positionId   String
  position     Position  @relation(fields: [positionId], references: [id])
  startDate    DateTime
  endDate      DateTime?
  isPrimary    Boolean   @default(true)
  isActive     Boolean   @default(true)
  notes        String?   @db.Text
  assignedById String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([positionId])
  @@index([isActive])
  @@map("employee_assignments")
}

// =============================================================================
// USERS & IDENTITY
// =============================================================================

model User {
  id                  String            @id @default(cuid())
  // Matricule — government-issued ID (e.g. "1.641.558", "478.432", "424.55")
  // MUST be stored as string: dots, varying formats, leading zeros must be preserved
  matriculeNumber     String?           @unique @db.VarChar(50)
  email               String            @unique @db.VarChar(255)
  passwordHash        String            @db.VarChar(255)
  firstName           String            @db.VarChar(100)
  lastName            String            @db.VarChar(100)
  displayName         String            @db.VarChar(200)
  avatarUrl           String?           @db.VarChar(500)
  userType            UserType          @default(GOVERNMENT_EMPLOYEE)
  // Legacy single-role field — kept for quick permission checks.
  // Source of truth is UserRoleAssignment join table.
  role                UserRole          @default(EMPLOYEE)
  status              UserStatus        @default(PENDING)
  preferredLanguage   SupportedLanguage @default(fr)
  // MFA
  mfaEnabled          Boolean           @default(false)
  mfaSecret           String?           @db.VarChar(512) // AES-256-GCM encrypted
  // Security tracking
  failedLoginCount    Int               @default(0)
  lockedUntil         DateTime?
  passwordChangedAt   DateTime?
  lastLoginAt         DateTime?
  lastLoginIp         String?           @db.VarChar(50)
  // Contact
  phone               String?           @db.VarChar(50)
  // Government structure
  ministryId          String?
  ministry            Ministry?         @relation(fields: [ministryId], references: [id])
  departmentId        String?
  department          Department?       @relation(fields: [departmentId], references: [id])
  divisionId          String?
  division            Division?         @relation(fields: [divisionId], references: [id])
  officeId            String?
  office              Office?           @relation(fields: [officeId], references: [id])
  // Manager (self-relation)
  managerId           String?
  manager             User?             @relation("Subordinates", fields: [managerId], references: [id])
  subordinates        User[]            @relation("Subordinates")
  // Identity relations
  roleAssignments     UserRoleAssignment[]
  sessions            UserSession[]
  devices             UserDevice[]
  loginHistory        LoginHistory[]
  passwordResetTokens PasswordResetToken[]
  passwordHistory     PasswordHistory[]
  mfaDevices          MfaDevice[]
  mfaBackupCodes      MfaBackupCode[]
  invitations         EmployeeInvitation[]
  // Government structure
  employeeAssignments EmployeeAssignment[]
  workforceTransfers  WorkforceTransfer[]
  // Collaboration relations (v0.7.0)
  sentMessages           Message[]            @relation("SentMessages")
  channelMemberships     ChannelMember[]
  receivedMentions       Mention[]            @relation("ReceivedMentions")
  readReceipts           ReadReceipt[]        @relation("ReadReceipts")
  conversationMemberships ConversationMember[] @relation("ConversationMemberships")
  sentDirectMessages     DirectMessage[]      @relation("SentDirectMessages")
  dmReactions            DMReaction[]         @relation("DMReactions")
  conversationSettings   ConversationSettings[] @relation("ConversationSettings")
  notifications          Notification[]
  auditLogs              AuditLog[]
  uploadedFiles          File[]
  // Document relations (v0.8.0)
  authoredDocuments      Document[]           @relation("AuthoredDocuments")
  savedVersions          DocumentVersion[]    @relation("SavedVersions")
  documentShares         DocumentShare[]      @relation("SharingUser")
  receivedShares         DocumentShare[]      @relation("SharedWithUser")
  documentComments       DocumentComment[]    @relation("DocumentComments")
  createdTemplates       DocumentTemplate[]   @relation("CreatedTemplates")
  documentExports        DocumentExport[]     @relation("DocumentExports")
  approvalRequests       DocumentApproval[]   @relation("ApprovalRequests")
  approvalReviews        DocumentApproval[]   @relation("DocumentApprovals")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  deletedAt           DateTime?

  @@index([email])
  @@index([matriculeNumber])
  @@index([ministryId])
  @@index([departmentId])
  @@index([officeId])
  @@index([managerId])
  @@index([role])
  @@index([status])
  @@map("users")
}

// =============================================================================
// EMPLOYEE INVITATIONS (v0.6.0)
// =============================================================================

model EmployeeInvitation {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SHA-256 hash of the raw invitation token (raw token is in the email only)
  tokenHash   String    @unique @db.VarChar(255)
  expiresAt   DateTime
  used        Boolean   @default(false)
  usedAt      DateTime?
  invitedById String
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@map("employee_invitations")
}

// =============================================================================
// WORKFORCE TRANSFERS (v0.6.1)
// =============================================================================

model WorkforceTransfer {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transferredById  String
  // Organizational "from" snapshot (null = unchanged / no prior value)
  fromMinistryId   String?
  fromDepartmentId String?
  fromDivisionId   String?
  fromOfficeId     String?
  fromManagerId    String?
  fromPositionId   String?
  // Organizational "to" values
  toMinistryId     String?
  toDepartmentId   String?
  toDivisionId     String?
  toOfficeId       String?
  toManagerId      String?
  toPositionId     String?
  reason           String?  @db.Text
  effectiveDate    DateTime @default(now())
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("workforce_transfers")
}

// =============================================================================
// RBAC — ROLES & PERMISSIONS
// =============================================================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(100)
  displayName String   @db.VarChar(255)
  weight      Int
  isSystem    Boolean  @default(false)
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions  RolePermission[]
  assignments  UserRoleAssignment[]

  @@index([weight])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(100)
  displayName String   @db.VarChar(255)
  description String?  @db.Text
  resource    String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

// Scoped role assignment: a user may hold different roles in different orgs
model UserRoleAssignment {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId       String
  role         Role      @relation(fields: [roleId], references: [id])
  // Organizational scope (null = system-wide)
  ministryId   String?
  ministry     Ministry?   @relation(fields: [ministryId], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  divisionId   String?
  division     Division?   @relation(fields: [divisionId], references: [id])
  grantedById  String
  grantedAt    DateTime  @default(now())
  expiresAt    DateTime?
  isActive     Boolean   @default(true)

  @@unique([userId, roleId, ministryId, departmentId, divisionId])
  @@index([userId])
  @@index([roleId])
  @@index([ministryId])
  @@map("user_role_assignments")
}

// =============================================================================
// SESSIONS & DEVICES
// =============================================================================

model UserSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId     String?
  device       UserDevice? @relation(fields: [deviceId], references: [id])
  // Hashed JTI of the active refresh token (for rotation validation)
  refreshTokenJti String? @db.VarChar(255)
  // Token family for reuse detection
  tokenFamily  String    @db.VarChar(100)
  ipAddress    String    @db.VarChar(50)
  userAgent    String    @db.Text
  platform     String    @db.VarChar(50) // "web" | "desktop" | "mobile"
  isActive     Boolean   @default(true)
  lastUsedAt   DateTime  @default(now())
  revokedAt    DateTime?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([refreshTokenJti])
  @@index([tokenFamily])
  @@index([isActive])
  @@index([userId, isActive]) // compound: active sessions per user (v0.6.3)
  @@map("user_sessions")
}

model UserDevice {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String    @db.VarChar(255)
  platform    String    @db.VarChar(50)
  fingerprint String    @db.VarChar(255)
  trusted     Boolean   @default(false)
  lastSeenAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())

  sessions    UserSession[]

  @@unique([userId, fingerprint])
  @@index([userId])
  @@map("user_devices")
}

// =============================================================================
// LOGIN HISTORY
// =============================================================================

model LoginHistory {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  credential String   @db.VarChar(255) // matricule or email used (for auditing)
  success    Boolean
  failReason String?  @db.VarChar(100)
  ipAddress  String   @db.VarChar(50)
  userAgent  String   @db.Text
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([ipAddress])
  @@index([createdAt])
  @@map("login_history")
}

// =============================================================================
// PASSWORD MANAGEMENT
// =============================================================================

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SHA-256 hash of the raw token (raw token is in the email link only)
  tokenHash String   @unique @db.VarChar(255)
  used      Boolean  @default(false)
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("password_reset_tokens")
}

model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("password_history")
}

// =============================================================================
// MFA
// =============================================================================

model MfaDevice {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String    @db.VarChar(255)
  method       MfaMethod @default(TOTP)
  // FIDO2 / WebAuthn fields (future)
  credentialId String?   @db.VarChar(512)
  publicKey    String?   @db.Text
  counter      Int?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?

  @@index([userId])
  @@map("mfa_devices")
}

model MfaBackupCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String   @db.VarChar(255) // bcrypt hash
  isUsed    Boolean  @default(false)
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("mfa_backup_codes")
}

// =============================================================================
// CHANNELS & MESSAGING
// =============================================================================

model Channel {
  id             String          @id @default(cuid())
  name           String          @db.VarChar(100)
  slug           String?         @db.VarChar(120) // URL-safe name
  description    String?         @db.Text
  type           ChannelType     @default(PUBLIC)
  // Organizational scope — a channel belongs to exactly one org unit
  ministryId     String?
  ministry       Ministry?       @relation(fields: [ministryId], references: [id])
  departmentId   String?
  department     Department?     @relation(fields: [departmentId], references: [id])
  divisionId     String?
  division       Division?       @relation(fields: [divisionId], references: [id])
  provinceId     String?
  province       Province?       @relation(fields: [provinceId], references: [id])
  isArchived     Boolean         @default(false)
  archivedAt     DateTime?
  archivedById   String?
  createdById    String
  memberCount    Int             @default(0) // denormalised for perf
  lastMessageAt  DateTime?
  members        ChannelMember[]
  messages       Message[]
  pinnedMessages PinnedMessage[]
  mentions       Mention[]
  files          File[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([ministryId])
  @@index([departmentId])
  @@index([divisionId])
  @@index([provinceId])
  @@index([type])
  @@index([isArchived])
  @@map("channels")
}

model ChannelMember {
  id               String   @id @default(cuid())
  channelId        String
  channel          Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  isAdmin          Boolean  @default(false)
  muteNotifications Boolean @default(false)
  joinedAt         DateTime @default(now())
  lastReadAt       DateTime @default(now())
  leftAt           DateTime?

  @@unique([channelId, userId])
  @@index([channelId])
  @@index([userId])
  @@index([channelId, lastReadAt])
  @@map("channel_members")
}

model Message {
  id            String        @id @default(cuid())
  channelId     String
  channel       Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  senderId      String
  sender        User          @relation("SentMessages", fields: [senderId], references: [id])
  type          MessageType   @default(TEXT)
  content       String        @db.Text
  replyToId     String?
  replyTo       Message?      @relation("Replies", fields: [replyToId], references: [id])
  replies       Message[]     @relation("Replies")
  isPinned      Boolean       @default(false)
  pinnedMessage PinnedMessage?
  reactions     Reaction[]
  mentions      Mention[]
  readReceipts  ReadReceipt[]
  attachments   File[]        @relation("MessageFiles")
  editedAt      DateTime?
  deletedAt     DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([channelId])
  @@index([senderId])
  @@index([createdAt])
  @@index([channelId, createdAt]) // cursor pagination
  @@map("messages")
}

model Reaction {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  emoji     String   @db.VarChar(20)
  createdAt DateTime @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("reactions")
}

model PinnedMessage {
  id        String   @id @default(cuid())
  messageId String   @unique
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  channelId String
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  pinnedById String
  pinnedAt  DateTime @default(now())

  @@index([channelId])
  @@map("pinned_messages")
}

model Mention {
  id             String    @id @default(cuid())
  messageId      String
  message        Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  channelId      String
  channel        Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  // Who was mentioned
  userId         String
  user           User      @relation("ReceivedMentions", fields: [userId], references: [id], onDelete: Cascade)
  mentionedById  String
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId, isRead])
  @@index([messageId])
  @@index([channelId])
  @@map("mentions")
}

model ReadReceipt {
  id        String   @id @default(cuid())
  messageId String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation("ReadReceipts", fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now())

  @@unique([messageId, userId])
  @@index([messageId])
  @@index([userId])
  @@map("read_receipts")
}

// =============================================================================
// DIRECT MESSAGES & CONVERSATIONS (v0.7.0)
// Separate from org Channels — these are personal DMs and group chats.
// =============================================================================

model Conversation {
  id            String               @id @default(cuid())
  type          ConversationType     @default(DIRECT)
  name          String?              @db.VarChar(255) // null for 1:1 DMs
  avatarUrl     String?              @db.VarChar(500)
  createdById   String
  isArchived    Boolean              @default(false)
  lastMessageAt DateTime?
  members       ConversationMember[]
  messages      DirectMessage[]
  settings      ConversationSettings[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([createdById])
  @@index([lastMessageAt])
  @@map("conversations")
}

model ConversationMember {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation("ConversationMemberships", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime     @default(now())
  joinedAt       DateTime     @default(now())
  leftAt         DateTime?

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@index([userId])
  @@map("conversation_members")
}

model DirectMessage {
  id             String        @id @default(cuid())
  conversationId String
  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User          @relation("SentDirectMessages", fields: [senderId], references: [id])
  type           MessageType   @default(TEXT)
  content        String        @db.Text
  replyToId      String?
  replyTo        DirectMessage?  @relation("DMReplies", fields: [replyToId], references: [id])
  replies        DirectMessage[] @relation("DMReplies")
  reactions      DMReaction[]
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([conversationId, createdAt]) // cursor pagination
  @@index([senderId])
  @@map("direct_messages")
}

model DMReaction {
  id        String        @id @default(cuid())
  messageId String
  message   DirectMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User          @relation("DMReactions", fields: [userId], references: [id], onDelete: Cascade)
  emoji     String        @db.VarChar(20)
  createdAt DateTime      @default(now())

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("dm_reactions")
}

model ConversationSettings {
  id                String       @id @default(cuid())
  conversationId    String
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId            String
  user              User         @relation("ConversationSettings", fields: [userId], references: [id], onDelete: Cascade)
  muteNotifications Boolean      @default(false)
  mutedUntil        DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@unique([conversationId, userId])
  @@index([conversationId])
  @@map("conversation_settings")
}

// =============================================================================
// FILE STORAGE
// NOTE: Actual files are stored in MinIO/S3. Only metadata lives here.
// =============================================================================

model File {
  id           String      @id @default(cuid())
  name         String      @db.VarChar(255)
  originalName String      @db.VarChar(255)
  mimeType     String      @db.VarChar(127)
  size         BigInt
  category     FileCategory @default(OTHER)
  status       FileStatus  @default(PENDING)
  storageKey   String      @db.VarChar(500)
  bucketName   String      @db.VarChar(100)
  checksum     String?     @db.VarChar(64)
  uploadedById String
  uploadedBy   User        @relation(fields: [uploadedById], references: [id])
  channelId    String?
  channel      Channel?    @relation(fields: [channelId], references: [id])
  messageId    String?
  message      Message?    @relation("MessageFiles", fields: [messageId], references: [id])
  isPublic     Boolean     @default(false)
  deletedAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([uploadedById])
  @@index([channelId])
  @@index([messageId])
  @@index([storageKey])
  @@map("files")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String           @db.VarChar(255)
  body      String           @db.Text
  data      Json             @default("{}")
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

// =============================================================================
// AUDIT LOGS — IMMUTABLE (app user has INSERT + SELECT only, never UPDATE/DELETE)
// =============================================================================

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  user       User?       @relation(fields: [userId], references: [id])
  action     AuditAction
  entityType String?     @db.VarChar(100)
  entityId   String?     @db.VarChar(100)
  metadata   Json        @default("{}")
  ipAddress  String?     @db.VarChar(50)
  userAgent  String?     @db.Text
  createdAt  DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([entityType, entityId])
  // Compound indexes for common dashboard/filter query patterns (v0.6.3 performance)
  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// =============================================================================
// DOCUMENTS & WRITER PLATFORM (v0.8.0)
// =============================================================================

model Document {
  id             String                 @id @default(cuid())
  title          String                 @db.VarChar(500)
  slug           String                 @unique @db.VarChar(500)
  type           DocumentType           @default(OTHER)
  status         DocumentStatus         @default(DRAFT)
  classification DocumentClassification @default(INTERNAL)
  // TipTap ProseMirror JSON content
  content        Json                   @default("{}")
  // Plain-text extract for search
  contentText    String?                @db.Text
  wordCount      Int                    @default(0)
  // Template reference
  templateId     String?
  template       DocumentTemplate?      @relation(fields: [templateId], references: [id])
  // Ownership
  authorId       String
  author         User                   @relation("AuthoredDocuments", fields: [authorId], references: [id])
  // Org scope (optional)
  ministryId     String?
  ministry       Ministry?              @relation(fields: [ministryId], references: [id])
  departmentId   String?
  department     Department?            @relation(fields: [departmentId], references: [id])
  divisionId     String?
  division       Division?              @relation(fields: [divisionId], references: [id])
  tags           String[]
  // Soft delete
  deletedAt      DateTime?
  deletedById    String?
  // Relations
  versions       DocumentVersion[]
  shares         DocumentShare[]
  comments       DocumentComment[]
  exports        DocumentExport[]
  approvals      DocumentApproval[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([authorId])
  @@index([status])
  @@index([classification])
  @@index([ministryId])
  @@index([type])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("documents")
}

model DocumentVersion {
  id          String   @id @default(cuid())
  documentId  String
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  version     Int
  title       String   @db.VarChar(500)
  content     Json
  contentText String?  @db.Text
  wordCount   Int      @default(0)
  savedById   String
  savedBy     User     @relation("SavedVersions", fields: [savedById], references: [id])
  changeNote  String?  @db.VarChar(500)
  createdAt   DateTime @default(now())

  @@unique([documentId, version])
  @@index([documentId])
  @@index([createdAt])
  @@map("document_versions")
}

model DocumentShare {
  id                 String             @id @default(cuid())
  documentId         String
  document           Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  scope              DocumentShareScope
  // Target — exactly one set
  targetUserId       String?
  targetUser         User?              @relation("SharedWithUser", fields: [targetUserId], references: [id])
  targetMinistryId   String?
  targetMinistry     Ministry?          @relation(fields: [targetMinistryId], references: [id])
  targetDepartmentId String?
  targetDepartment   Department?        @relation(fields: [targetDepartmentId], references: [id])
  targetDivisionId   String?
  targetDivision     Division?          @relation(fields: [targetDivisionId], references: [id])
  // Permissions
  canEdit            Boolean            @default(false)
  canComment         Boolean            @default(true)
  canExport          Boolean            @default(false)
  sharedById         String
  sharedBy           User               @relation("SharingUser", fields: [sharedById], references: [id])
  expiresAt          DateTime?
  createdAt          DateTime           @default(now())

  @@index([documentId])
  @@index([targetUserId])
  @@index([targetMinistryId])
  @@index([targetDepartmentId])
  @@index([targetDivisionId])
  @@map("document_shares")
}

model DocumentComment {
  id           String            @id @default(cuid())
  documentId   String
  document     Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  authorId     String
  author       User              @relation("DocumentComments", fields: [authorId], references: [id])
  content      String            @db.Text
  replyToId    String?
  replyTo      DocumentComment?  @relation("CommentReplies", fields: [replyToId], references: [id])
  replies      DocumentComment[] @relation("CommentReplies")
  resolvedAt   DateTime?
  resolvedById String?
  deletedAt    DateTime?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([documentId])
  @@index([authorId])
  @@map("document_comments")
}

model DocumentTemplate {
  id             String                 @id @default(cuid())
  name           String                 @db.VarChar(255)
  description    String?                @db.Text
  type           DocumentType
  classification DocumentClassification @default(INTERNAL)
  content        Json                   @default("{}")
  isActive       Boolean                @default(true)
  createdById    String
  createdBy      User                   @relation("CreatedTemplates", fields: [createdById], references: [id])
  ministryId     String?
  ministry       Ministry?              @relation(fields: [ministryId], references: [id])
  documents      Document[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  @@index([type])
  @@index([ministryId])
  @@map("document_templates")
}

model DocumentExport {
  id           String               @id @default(cuid())
  documentId   String
  document     Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  format       DocumentExportFormat
  versionId    String?
  exportedById String
  exportedBy   User                 @relation("DocumentExports", fields: [exportedById], references: [id])
  fileSize     Int?
  storageKey   String?              @db.VarChar(500)
  expiresAt    DateTime?
  createdAt    DateTime             @default(now())

  @@index([documentId])
  @@index([exportedById])
  @@map("document_exports")
}

model DocumentApproval {
  id            String         @id @default(cuid())
  documentId    String
  document      Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  approverId    String
  approver      User           @relation("DocumentApprovals", fields: [approverId], references: [id])
  status        ApprovalStatus @default(PENDING)
  requestedById String
  requestedBy   User           @relation("ApprovalRequests", fields: [requestedById], references: [id])
  comment       String?        @db.Text
  reviewedAt    DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([documentId])
  @@index([approverId])
  @@index([status])
  @@map("document_approvals")
}

// =============================================================================
// WORKFLOWS & APPROVALS (v0.8.1)
// =============================================================================

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
  REJECTED
}

enum StepStatus {
  PENDING
  IN_PROGRESS
  APPROVED
  REJECTED
  SKIPPED
  RETURNED
  DELEGATED
}

enum ApprovalDecisionEnum {
  APPROVED
  REJECTED
  REQUEST_CHANGES
  DELEGATED
  ESCALATED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum WorkflowTrigger {
  MANUAL
  DOCUMENT_CREATED
  DOCUMENT_PUBLISHED
  EMPLOYEE_TRANSFERRED
  BUDGET_SUBMITTED
  CONTRACT_UPLOADED
  CUSTOM
}

// ─── Workflow Templates ───────────────────────────────────────────────────────

model WorkflowTemplate {
  id             String          @id @default(cuid())
  name           String          @db.VarChar(255)
  description    String?         @db.Text
  slug           String          @unique @db.VarChar(255)
  trigger        WorkflowTrigger @default(MANUAL)
  stepDefinitions Json           @default("[]")   // ordered array of step configs
  isSystem       Boolean         @default(false)   // built-in government templates
  isActive       Boolean         @default(true)
  ministryId     String?
  ministry       Ministry?       @relation(fields: [ministryId], references: [id])
  createdById    String
  createdBy      User            @relation("CreatedWorkflowTemplates", fields: [createdById], references: [id])
  definitions    WorkflowDefinition[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([ministryId])
  @@index([isActive])
  @@map("workflow_templates")
}

// ─── Workflow Definitions ─────────────────────────────────────────────────────

model WorkflowDefinition {
  id           String           @id @default(cuid())
  title        String           @db.VarChar(500)
  description  String?          @db.Text
  templateId   String?
  template     WorkflowTemplate? @relation(fields: [templateId], references: [id])
  trigger      WorkflowTrigger  @default(MANUAL)
  isActive     Boolean          @default(true)
  ministryId   String?
  ministry     Ministry?        @relation(fields: [ministryId], references: [id])
  createdById  String
  createdBy    User             @relation("CreatedWorkflowDefinitions", fields: [createdById], references: [id])
  steps        WorkflowStep[]
  instances    WorkflowInstance[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([ministryId])
  @@index([isActive])
  @@map("workflow_definitions")
}

// ─── Workflow Steps ───────────────────────────────────────────────────────────

model WorkflowStep {
  id             String             @id @default(cuid())
  definitionId   String
  definition     WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)
  order          Int
  name           String             @db.VarChar(255)
  description    String?            @db.Text
  roleId         String?            // role required to approve this step
  assigneeId     String?            // specific user assigned
  assignee       User?              @relation("WorkflowStepAssignees", fields: [assigneeId], references: [id])
  durationHours  Int?               // SLA
  allowDelegate  Boolean            @default(true)
  allowEscalate  Boolean            @default(true)
  requireComment Boolean            @default(false)
  requireSign    Boolean            @default(false)
  assignments    WorkflowAssignment[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@unique([definitionId, order])
  @@index([definitionId])
  @@map("workflow_steps")
}

// ─── Workflow Instances ───────────────────────────────────────────────────────

model WorkflowInstance {
  id             String             @id @default(cuid())
  definitionId   String
  definition     WorkflowDefinition @relation(fields: [definitionId], references: [id])
  title          String             @db.VarChar(500)
  description    String?            @db.Text
  status         WorkflowStatus     @default(DRAFT)
  currentStep    Int                @default(0)
  totalSteps     Int                @default(0)
  initiatorId    String
  initiator      User               @relation("InitiatedWorkflows", fields: [initiatorId], references: [id])
  documentId     String?            // optional linked document
  metadata       Json               @default("{}")
  startedAt      DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  cancelledById  String?
  cancelledBy    User?              @relation("CancelledWorkflows", fields: [cancelledById], references: [id])
  dueAt          DateTime?
  deletedAt      DateTime?
  assignments    WorkflowAssignment[]
  approvals      WorkflowApproval[]
  comments       WorkflowComment[]
  history        WorkflowHistory[]
  tasks          Task[]
  signatures     DigitalSignature[]
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([status])
  @@index([initiatorId])
  @@index([definitionId])
  @@index([documentId])
  @@index([createdAt])
  @@map("workflow_instances")
}

// ─── Workflow Assignments (per-step per-instance) ─────────────────────────────

model WorkflowAssignment {
  id           String           @id @default(cuid())
  instanceId   String
  instance     WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  stepId       String
  step         WorkflowStep     @relation(fields: [stepId], references: [id])
  assigneeId   String
  assignee     User             @relation("WorkflowAssignments", fields: [assigneeId], references: [id])
  stepOrder    Int
  status       StepStatus       @default(PENDING)
  dueAt        DateTime?
  notifiedAt   DateTime?
  completedAt  DateTime?
  approval     WorkflowApproval?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([instanceId])
  @@index([assigneeId])
  @@index([status])
  @@map("workflow_assignments")
}

// ─── Workflow Approvals ───────────────────────────────────────────────────────

model WorkflowApproval {
  id             String               @id @default(cuid())
  instanceId     String
  instance       WorkflowInstance     @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  assignmentId   String               @unique
  assignment     WorkflowAssignment   @relation(fields: [assignmentId], references: [id])
  approverId     String
  approver       User                 @relation("WorkflowApprovals", fields: [approverId], references: [id])
  decision       ApprovalDecisionEnum
  comment        String?              @db.Text
  delegatedToId  String?
  delegatedTo    User?                @relation("DelegatedApprovals", fields: [delegatedToId], references: [id])
  stepOrder      Int
  decidedAt      DateTime             @default(now())
  signature      DigitalSignature?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([instanceId])
  @@index([approverId])
  @@map("workflow_approvals")
}

// ─── Workflow Comments ────────────────────────────────────────────────────────

model WorkflowComment {
  id         String           @id @default(cuid())
  instanceId String
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  authorId   String
  author     User             @relation("WorkflowComments", fields: [authorId], references: [id])
  content    String           @db.Text
  replyToId  String?
  replyTo    WorkflowComment? @relation("WorkflowReplies", fields: [replyToId], references: [id])
  replies    WorkflowComment[] @relation("WorkflowReplies")
  isInternal Boolean          @default(false)
  deletedAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([instanceId])
  @@index([authorId])
  @@map("workflow_comments")
}

// ─── Workflow History ─────────────────────────────────────────────────────────

model WorkflowHistory {
  id         String           @id @default(cuid())
  instanceId String
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User             @relation("WorkflowHistory", fields: [actorId], references: [id])
  action     String           @db.VarChar(100)
  stepOrder  Int?
  detail     String?          @db.Text
  metadata   Json             @default("{}")
  createdAt  DateTime         @default(now())

  @@index([instanceId])
  @@index([createdAt])
  @@map("workflow_history")
}

// ─── Digital Signatures ───────────────────────────────────────────────────────

model DigitalSignature {
  id           String            @id @default(cuid())
  instanceId   String
  instance     WorkflowInstance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  approvalId   String?           @unique
  approval     WorkflowApproval? @relation(fields: [approvalId], references: [id])
  signerId     String
  signer       User              @relation("DigitalSignatures", fields: [signerId], references: [id])
  signedAt     DateTime          @default(now())
  ipAddress    String?           @db.VarChar(45)
  userAgent    String?           @db.VarChar(500)
  certificateRef String?         @db.VarChar(255) // future PKI
  qrToken      String            @unique @default(cuid()) // QR verification
  revokedAt    DateTime?
  revokedById  String?
  revokedBy    User?             @relation("RevokedSignatures", fields: [revokedById], references: [id])
  createdAt    DateTime          @default(now())

  @@index([instanceId])
  @@index([signerId])
  @@index([qrToken])
  @@map("digital_signatures")
}

// ─── Tasks ────────────────────────────────────────────────────────────────────

model Task {
  id           String       @id @default(cuid())
  title        String       @db.VarChar(500)
  description  String?      @db.Text
  status       TaskStatus   @default(TODO)
  priority     TaskPriority @default(MEDIUM)
  assigneeId   String?
  assignee     User?        @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdById  String
  createdBy    User         @relation("CreatedTasks", fields: [createdById], references: [id])
  instanceId   String?
  instance     WorkflowInstance? @relation(fields: [instanceId], references: [id])
  documentId   String?
  dueAt        DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  deletedAt    DateTime?
  tags         String[]     @default([])
  comments     TaskComment[]
  attachments  TaskAttachment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([assigneeId])
  @@index([status])
  @@index([instanceId])
  @@index([dueAt])
  @@index([createdAt])
  @@map("tasks")
}

// ─── Task Comments ────────────────────────────────────────────────────────────

model TaskComment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("TaskComments", fields: [authorId], references: [id])
  content   String   @db.Text
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
  @@map("task_comments")
}

// ─── Task Attachments ─────────────────────────────────────────────────────────

model TaskAttachment {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedById String
  uploadedBy   User     @relation("TaskAttachments", fields: [uploadedById], references: [id])
  filename     String   @db.VarChar(500)
  mimeType     String   @db.VarChar(100)
  sizeBytes    Int
  storageKey   String   @db.VarChar(1000)
  createdAt    DateTime @default(now())

  @@index([taskId])
  @@map("task_attachments")
}
