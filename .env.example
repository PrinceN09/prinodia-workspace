# =============================================================================
# GovSphere — Environment Variables Reference
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.
# The application will FAIL TO START if required variables are missing.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
APP_NAME=GovSphere
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
WS_URL=ws://localhost:4000

# -----------------------------------------------------------------------------
# Database (PostgreSQL 17)
# Required. The application will not start without a valid DATABASE_URL.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://govsphere:CHANGE_ME_DB_PASSWORD@localhost:5432/govsphere_db

# Shadow database used by Prisma migrate (must be a separate DB from DATABASE_URL)
SHADOW_DATABASE_URL=postgresql://govsphere:CHANGE_ME_DB_PASSWORD@localhost:5432/govsphere_shadow_db

# -----------------------------------------------------------------------------
# Redis (Cache & Queues)
# Required. Used for session blacklist, BullMQ job queues, Socket.IO adapter.
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# BullMQ uses a separate DB index to isolate job queues from session cache
BULLMQ_REDIS_DB=1

# -----------------------------------------------------------------------------
# Authentication — JWT RS256 (Asymmetric)
#
# GovSphere uses RS256 asymmetric signing.
# The private key signs tokens; the public key verifies them.
# Keys must be base64-encoded PEM strings (no line breaks).
#
# Generate keys:
#   openssl genrsa -out jwt-private.pem 4096
#   openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
#   base64 -i jwt-private.pem | tr -d '\n'   # → JWT_PRIVATE_KEY
#   base64 -i jwt-public.pem  | tr -d '\n'   # → JWT_PUBLIC_KEY
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY=CHANGE_ME_BASE64_ENCODED_RS256_PRIVATE_KEY_PEM
JWT_PUBLIC_KEY=CHANGE_ME_BASE64_ENCODED_RS256_PUBLIC_KEY_PEM
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# MFA Encryption
# AES-256-GCM key for encrypting TOTP secrets at rest.
# Must be exactly 64 hex characters (32 bytes).
#
# Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
MFA_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS_AES256_KEY_00000000000000000000000000000000
MFA_ISSUER=GovSphere

# -----------------------------------------------------------------------------
# MinIO (File Storage — S3-compatible)
# Required. All files are stored in MinIO, never in PostgreSQL.
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_BUCKET_FILES=govsphere-files
MINIO_BUCKET_AVATARS=govsphere-avatars
MINIO_BUCKET_DOCUMENTS=govsphere-documents

# Public URL for browser access (use API proxy in production — never expose MinIO directly)
MINIO_PUBLIC_URL=http://localhost:9000

# -----------------------------------------------------------------------------
# Email (SMTP)
# MailHog for local development. Use a real SMTP provider in production.
# MailHog Web UI: http://localhost:8025
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=GovSphere
SMTP_FROM_EMAIL=noreply@govsphere.gouv.cd

# -----------------------------------------------------------------------------
# Next.js Web Application
# NEXT_PUBLIC_* variables are exposed to the browser bundle.
# -----------------------------------------------------------------------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=CHANGE_ME_NEXTAUTH_SECRET_AT_LEAST_32_CHARS
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=GovSphere
NEXT_PUBLIC_APP_VERSION=0.1.0

# -----------------------------------------------------------------------------
# Keycloak (Optional SSO — future, external partners only)
# Not required for v0.1.0 — comment out if not used.
# -----------------------------------------------------------------------------
# KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_REALM=govsphere
# KEYCLOAK_CLIENT_ID=govsphere-api
# KEYCLOAK_CLIENT_SECRET=CHANGE_ME_KEYCLOAK_CLIENT_SECRET

# -----------------------------------------------------------------------------
# Search (OpenSearch — Sprint 5)
# Not required for v0.1.0 — comment out if not used.
# -----------------------------------------------------------------------------
# OPENSEARCH_URL=http://localhost:9200
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=CHANGE_ME_OPENSEARCH_PASSWORD

# -----------------------------------------------------------------------------
# Security & Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# File Upload
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf,docx,xlsx,pptx,txt,csv,png,jpg,jpeg,gif,webp,mp4,mp3

# -----------------------------------------------------------------------------
# Logging
# Pino log level: trace | debug | info | warn | error | fatal
# -----------------------------------------------------------------------------
LOG_LEVEL=info
AUDIT_LOG_RETENTION_DAYS=365

# -----------------------------------------------------------------------------
# Government Structure Defaults
# -----------------------------------------------------------------------------
DEFAULT_COUNTRY_CODE=CD
DEFAULT_TIMEZONE=Africa/Kinshasa
DEFAULT_LANGUAGE=fr
SUPPORTED_LANGUAGES=fr,en,ln,sw,lua

# -----------------------------------------------------------------------------
# pgAdmin (Docker Dev only — not used in production)
# -----------------------------------------------------------------------------
PGADMIN_EMAIL=admin@govsphere.local
PGADMIN_PASSWORD=admin
